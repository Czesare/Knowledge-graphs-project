@prefix hint: <https://w3id.org/hi-thesaurus/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

hint:AdaptiveAutonomyCapability a skos:Concept ;
    skos:broader hint:ReinforcementLearningCapability ;
    skos:definition "The ability of a system to dynamically adjust its level of autonomy based on contextual and user-specific factors."@en ;
    skos:inScheme hint:HIScheme ;
    skos:prefLabel "Adaptive Autonomy Capability"@en .

hint:BilingualMappingCapability a skos:Concept ;
    skos:broader hint:Capability ;
    skos:definition "The ability to map and translate information between two languages effectively."@en ;
    skos:inScheme hint:HIScheme ;
    skos:prefLabel "Bilingual Mapping Capability"@en .

hint:ComplexClaimVerificationTask a skos:Concept ;
    skos:broader hint:Task ;
    skos:definition "A task involving the verification of claims with multiple implicit and explicit sub-claims."@en ;
    skos:inScheme hint:HIScheme ;
    skos:prefLabel "Complex Claim Verification Task"@en .

hint:CulturalPreservationTask a skos:Concept ;
    skos:broader hint:Task ;
    skos:definition "A task focused on preserving cultural heritage and practices."@en ;
    skos:inScheme hint:HIScheme ;
    skos:prefLabel "Cultural Preservation Task"@en .

hint:CybersecurityContext a skos:Concept ;
    skos:broader hint:WorkspaceManipulationContext ;
    skos:definition "A context involving the protection of systems, networks, and programs from digital attacks."@en ;
    skos:inScheme hint:HIScheme ;
    skos:prefLabel "Cybersecurity Context"@en .

hint:EmergencyResponseContext a skos:Concept ;
    skos:broader hint:WorkspaceManipulationContext ;
    skos:definition "The context in which emergency responders operate, characterized by dynamic and unpredictable environments."@en ;
    skos:inScheme hint:HIScheme ;
    skos:prefLabel "Emergency Response Context"@en .

hint:ExplanationStreamPattern a skos:Concept ;
    skos:broader hint:InteractionModality ;
    skos:definition "Reusable solutions that govern the stream of explanations between users and systems."@en ;
    skos:inScheme hint:HIScheme ;
    skos:prefLabel "Explanation Stream Pattern"@en .

hint:FaceMatchingContext a skos:Concept ;
    skos:broader hint:JuryDeliberationContext ;
    skos:definition "A context where human operators use decision support systems to match faces."@en ;
    skos:inScheme hint:HIScheme ;
    skos:prefLabel "Face Matching Context"@en .

hint:InformationQualityIndicator a skos:Concept ;
    skos:broader hint:Capability ;
    skos:definition "A metric used to assess the quality of information in data items."@en ;
    skos:inScheme hint:HIScheme ;
    skos:prefLabel "Information Quality Indicator"@en .

hint:MoltenMetalHandling a skos:Concept ;
    skos:broader hint:WorkspaceManipulationContext ;
    skos:definition "The process of managing and transporting molten metals in industrial settings."@en ;
    skos:inScheme hint:HIScheme ;
    skos:prefLabel "Molten Metal Handling"@en .

hint:OrthogonalityLossCapability a skos:Concept ;
    skos:broader hint:Capability ;
    skos:definition "The ability to apply orthogonality constraints to enhance feature diversity and robustness."@en ;
    skos:inScheme hint:HIScheme ;
    skos:prefLabel "Orthogonality Loss Capability"@en .

hint:ProteinAnalysisTask a skos:Concept ;
    skos:broader hint:SymptomAnalysisTask ;
    skos:definition "Task involving the analysis of protein structures for therapeutic potential."@en ;
    skos:inScheme hint:HIScheme ;
    skos:prefLabel "Protein Analysis Task"@en .

hint:RobotInteractionTask a skos:Concept ;
    skos:broader hint:Task ;
    skos:definition "A task involving interaction between a human and a robot to achieve educational goals."@en ;
    skos:inScheme hint:HIScheme ;
    skos:prefLabel "Robot Interaction Task"@en .

hint:SocialConversationContext a skos:Concept ;
    skos:broader hint:OnlineLearningContext ;
    skos:definition "A context involving informal exchanges between individuals, often involving personal perspectives and implicit information."@en ;
    skos:inScheme hint:HIScheme ;
    skos:prefLabel "Social Conversation Context"@en .

hint:TaskPlanningTask a skos:Concept ;
    skos:broader hint:Task ;
    skos:definition "A task involving the planning and organization of educational activities."@en ;
    skos:inScheme hint:HIScheme ;
    skos:prefLabel "Task Planning Task"@en .


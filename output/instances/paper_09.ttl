@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix hi: <https://w3id.org/hi-ontology#> .
@prefix hint: <https://w3id.org/hi-thesaurus/> .
@prefix inst: <https://w3id.org/hi-ontology/instances/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

inst:Paper_09 a hi:Paper ;
    hi:describesUseCase inst:Paper_09_UseCase ;
    hi:hasAuthor inst:Paper_09_Author1,
        inst:Paper_09_Author2,
        inst:Paper_09_Author3,
        inst:Paper_09_Author4,
        inst:Paper_09_Author5,
        inst:Paper_09_Author6,
        inst:Paper_09_Author7,
        inst:Paper_09_Author8 ;
    hi:hasKeyword inst:Keyword_DataPrivacy,
        inst:Keyword_GenerativeAiChatbot,
        inst:Keyword_Llm,
        inst:Keyword_PublicSectorAi,
        inst:Keyword_Reliability,
        inst:Keyword_Retrieval-augmentedGenerationRag,
        inst:Keyword_Robustness,
        inst:Keyword_Trustworthiness ;
    hi:hasPublicationYear "2025"^^xsd:gYear ;
    hi:hasTitle "Towards Building a Trustworthy RAG-Based Chatbot for the Italian Public Administration"^^xsd:string ;
    hi:publishedAt inst:HHAI2025 .

inst:Paper_09_Interaction_UserQueryInteraction a hi:Interaction ;
    rdfs:label "User Query Interaction" ;
    hi:hasAgentInvolved inst:Paper_09_GovernmentEmployee,
        inst:Paper_09_RagChatbot ;
    hi:hasInteractionIntentConcept hint:AnswerIntent ;
    hi:hasInteractionModalityConcept hint:TextChatModality .

inst:HHAI2025 a hi:Conference ;
    rdfs:label "HHAI 2025" ;
    hi:hasConferenceName "HHAI 2025"^^xsd:string ;
    hi:hasConferenceYear "2025"^^xsd:gYear .

inst:Keyword_DataPrivacy a skos:Concept ;
    skos:inScheme hint:HIScheme ;
    skos:prefLabel "Data Privacy"@en .

inst:Keyword_GenerativeAiChatbot a skos:Concept ;
    skos:inScheme hint:HIScheme ;
    skos:prefLabel "Generative AI Chatbot"@en .

inst:Keyword_Llm a skos:Concept ;
    skos:inScheme hint:HIScheme ;
    skos:prefLabel "LLM"@en .

inst:Keyword_PublicSectorAi a skos:Concept ;
    skos:inScheme hint:HIScheme ;
    skos:prefLabel "Public Sector AI"@en .

inst:Keyword_Reliability a skos:Concept ;
    skos:inScheme hint:HIScheme ;
    skos:prefLabel "Reliability"@en .

inst:Keyword_Retrieval-augmentedGenerationRag a skos:Concept ;
    skos:inScheme hint:HIScheme ;
    skos:prefLabel "Retrieval-Augmented Generation (RAG)"@en .

inst:Keyword_Robustness a skos:Concept ;
    skos:inScheme hint:HIScheme ;
    skos:prefLabel "Robustness"@en .

inst:Keyword_Trustworthiness a skos:Concept ;
    skos:inScheme hint:HIScheme ;
    skos:prefLabel "Trustworthiness"@en .

inst:Paper_09_Author1 a hi:Author ;
    foaf:name "Chandana Sree MALA" ;
    hi:hasAffiliation inst:Affiliation_DepartmentOfInformaticsScuolaNormaleSuperiore ;
    hi:hasAuthorName "Chandana Sree MALA"^^xsd:string .

inst:Paper_09_Author2 a hi:Author ;
    foaf:name "Christian DIMAIO" ;
    hi:hasAffiliation inst:Affiliation_DepartmentOfInformationEngineeringUniversityOfSiena ;
    hi:hasAuthorName "Christian DIMAIO"^^xsd:string .

inst:Paper_09_Author3 a hi:Author ;
    foaf:name "Mattia PROIETTI" ;
    hi:hasAffiliation inst:Affiliation_DepartmentOfPhilologyLiteratureAndLinguisticsUniversityOfPisa ;
    hi:hasAuthorName "Mattia PROIETTI"^^xsd:string .

inst:Paper_09_Author4 a hi:Author ;
    foaf:name "Gizem GEZICI" ;
    hi:hasAffiliation inst:Affiliation_DepartmentOfInformaticsScuolaNormaleSuperiore ;
    hi:hasAuthorName "Gizem GEZICI"^^xsd:string .

inst:Paper_09_Author5 a hi:Author ;
    foaf:name "Fosca GIANNOTTI" ;
    hi:hasAffiliation inst:Affiliation_DepartmentOfInformaticsScuolaNormaleSuperiore ;
    hi:hasAuthorName "Fosca GIANNOTTI"^^xsd:string .

inst:Paper_09_Author6 a hi:Author ;
    foaf:name "Stefano MELACCI" ;
    hi:hasAffiliation inst:Affiliation_DepartmentOfInformationEngineeringUniversityOfSiena ;
    hi:hasAuthorName "Stefano MELACCI"^^xsd:string .

inst:Paper_09_Author7 a hi:Author ;
    foaf:name "Alessandro LENCI" ;
    hi:hasAffiliation inst:Affiliation_DepartmentOfPhilologyLiteratureAndLinguisticsUniversityOfPisa ;
    hi:hasAuthorName "Alessandro LENCI"^^xsd:string .

inst:Paper_09_Author8 a hi:Author ;
    foaf:name "Marco GORI" ;
    hi:hasAffiliation inst:Affiliation_DepartmentOfInformationEngineeringUniversityOfSiena ;
    hi:hasAuthorName "Marco GORI"^^xsd:string .

inst:Paper_09_Context a hi:Context ;
    rdfs:label "Public Administration Support" ;
    hi:hasConstraintConcept hint:PrivacyConstraint,
        hint:TransparencyConstraint ;
    hi:hasContextConcept hint:JuryDeliberationContext ;
    hi:hasInfluenceOn inst:Paper_09_Team ;
    hi:hasPhenomenonConcept hint:KnowledgeMismatchPhenomenon .

inst:Paper_09_Exec_ExecuteInformationRetrieval a hi:TaskExecution ;
    rdfs:label "Execute Information Retrieval" ;
    hi:evaluatedBy inst:Paper_09_Evaluation ;
    hi:hasMethodConcept hint:KnowledgeGraphQueryMethod ;
    hi:realizesTask inst:Paper_09_Task_RetrieveRelevantInformation .

inst:Paper_09_Exec_ExecuteResponseGeneration a hi:TaskExecution ;
    rdfs:label "Execute Response Generation" ;
    hi:evaluatedBy inst:Paper_09_Evaluation ;
    hi:hasMethodConcept hint:PostHocExplanationMethod ;
    hi:realizesTask inst:Paper_09_Task_GenerateUser-friendlyResponses .

inst:Paper_09_Experiment_RagChatbotEvaluation a hi:Experiment ;
    rdfs:label "RAG Chatbot Evaluation" ;
    hi:hasAlternativeHypothesis "The RAG chatbot improves task success rate."^^xsd:string ;
    hi:hasExperimentConcept hint:DeliberationSupportExperiment ;
    hi:hasMetricTested hint:TaskSuccessRateMetric ;
    hi:hasNullHypothesis "The RAG chatbot does not improve task success rate."^^xsd:string .

inst:Paper_09_Goal_ProvideAccurateInformation a hi:Goal ;
    rdfs:label "Provide Accurate Information" ;
    hi:hasGoalConcept hint:FairAccurateVerdictGoal ;
    hi:requiresTask inst:Paper_09_Task_EnsureDataPrivacy,
        inst:Paper_09_Task_GenerateUser-friendlyResponses,
        inst:Paper_09_Task_RetrieveRelevantInformation .

inst:Paper_09_GovernmentEmployee_Cap_ContextualUnderstanding a hi:Capability ;
    rdfs:label "Contextual Understanding" ;
    hi:allowsTask inst:Paper_09_Task_EnsureDataPrivacy ;
    hi:hasCapabilityConcept hint:SituationalAwarenessCapability .

inst:Paper_09_RagChatbot_Cap_MultilingualEmbedding a hi:Capability ;
    rdfs:label "Knowledge Graph Retrieval" ;
    hi:allowsTask inst:Paper_09_Task_RetrieveRelevantInformation ;
    hi:hasCapabilityConcept hint:KnowledgeGraphQueryingCapability .

inst:Paper_09_RagChatbot_Cap_ResponseGeneration a hi:Capability ;
    rdfs:label "Response Generation" ;
    hi:allowsTask inst:Paper_09_Task_GenerateUser-friendlyResponses ;
    hi:hasCapabilityConcept hint:ExplainingCapability .

inst:Paper_09_RagChatbot_Cap_SemanticRetrieval a hi:Capability ;
    rdfs:label "Semantic Retrieval" ;
    hi:hasCapabilityConcept hint:SemanticReasoningCapability .

inst:Paper_09_Task_EnsureDataPrivacy a hi:Task ;
    rdfs:label "Ensure Data Privacy" ;
    hi:hasTaskConcept hint:DataCollectionTask ;
    hi:requiresCapability inst:Paper_09_GovernmentEmployee_Cap_ContextualUnderstanding .

inst:Paper_09_UseCase a hi:ResearchUseCase ;
    rdfs:label "Trustworthy RAG Chatbot for Public Administration" ;
    hi:hasDomainConcept hint:LawAndPolicyDomain ;
    hi:hasHITeam inst:Paper_09_Team .

inst:Affiliation_DepartmentOfPhilologyLiteratureAndLinguisticsUniversityOfPisa a hi:Affiliation ;
    rdfs:label "Department of Philology, Literature and Linguistics, University of Pisa" ;
    schema1:name "Department of Philology, Literature and Linguistics, University of Pisa" .

inst:Paper_09_Evaluation a hi:Evaluation ;
    rdfs:label "Chatbot Performance Evaluation" ;
    hi:hasEvaluationConcept hint:AIInterventionImpactEvaluation ;
    hi:hasExperiment inst:Paper_09_Experiment_RagChatbotEvaluation ;
    hi:hasMetricConcept hint:TaskSuccessRateMetric,
        hint:TrustPreservationMetric .

inst:Paper_09_GovernmentEmployee a hi:HumanAgent ;
    rdfs:label "Government Employee" ;
    hi:hasCapability inst:Paper_09_GovernmentEmployee_Cap_ContextualUnderstanding,
        inst:Paper_09_GovernmentEmployee_Cap_DomainJudgment ;
    hi:hasRoleConcept hint:HumanUserRole .

inst:Paper_09_RagChatbot a hi:ArtificialAgent ;
    rdfs:label "RAG Chatbot" ;
    hi:hasCapability inst:Paper_09_RagChatbot_Cap_MultilingualEmbedding,
        inst:Paper_09_RagChatbot_Cap_ResponseGeneration,
        inst:Paper_09_RagChatbot_Cap_SemanticRetrieval ;
    hi:hasRoleConcept hint:AIAssistantRole ;
    hi:performsExecution inst:Paper_09_Exec_ExecuteInformationRetrieval,
        inst:Paper_09_Exec_ExecuteResponseGeneration .

inst:Paper_09_Task_GenerateUser-friendlyResponses a hi:Task ;
    rdfs:label "Generate User-Friendly Responses" ;
    hi:hasTaskConcept hint:ExplanationTask ;
    hi:requiresCapability inst:Paper_09_RagChatbot_Cap_ResponseGeneration .

inst:Paper_09_Task_RetrieveRelevantInformation a hi:Task ;
    rdfs:label "Retrieve Relevant Information" ;
    hi:hasTaskConcept hint:KnowledgeGraphQueryTask ;
    hi:requiresCapability inst:Paper_09_RagChatbot_Cap_MultilingualEmbedding .

inst:Paper_09_Team a hi:HITeam ;
    rdfs:label "Trustworthy RAG Chatbot for Public Administration Team" ;
    hi:hasGoal inst:Paper_09_Goal_ProvideAccurateInformation ;
    hi:hasMember inst:Paper_09_GovernmentEmployee,
        inst:Paper_09_RagChatbot ;
    hi:isInfluencedBy inst:Paper_09_Context .

inst:Affiliation_DepartmentOfInformaticsScuolaNormaleSuperiore a hi:Affiliation ;
    rdfs:label "Department of Informatics, Scuola Normale Superiore" ;
    schema1:name "Department of Informatics, Scuola Normale Superiore" .

inst:Affiliation_DepartmentOfInformationEngineeringUniversityOfSiena a hi:Affiliation ;
    rdfs:label "Department of Information Engineering, University of Siena" ;
    schema1:name "Department of Information Engineering, University of Siena" .

inst:Paper_09_GovernmentEmployee_Cap_DomainJudgment a hi:Capability ;
    rdfs:label "Domain Judgment" ;
    hi:hasCapabilityConcept hint:ClinicalJudgmentCapability .


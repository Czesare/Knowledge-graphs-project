@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix hi: <https://w3id.org/hi-ontology#> .
@prefix hint: <https://w3id.org/hi-thesaurus/> .
@prefix inst: <https://w3id.org/hi-ontology/instances/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

inst:Paper_05 a hi:Paper ;
    hi:describesUseCase inst:Paper_05_UseCase ;
    hi:hasAuthor inst:Paper_05_Author1,
        inst:Paper_05_Author2,
        inst:Paper_05_Author3,
        inst:Paper_05_Author4 ;
    hi:hasKeyword inst:Keyword_AutonomousSystems,
        inst:Keyword_EthicalTrust,
        inst:Keyword_HybridAutonomy ;
    hi:hasPublicationYear "2025"^^xsd:gYear ;
    hi:hasTitle "Hybrid Autonomy: Towards a Unified Framework on Adaptability and Ethical Trust in Autonomous Systems"^^xsd:string ;
    hi:publishedAt inst:HHAI2025 .

inst:Paper_05_Interaction_Robot-patientInteraction a hi:Interaction ;
    rdfs:label "Robot-Patient Interaction" ;
    hi:hasAgentInvolved inst:Paper_05_AssistiveRobot,
        inst:Paper_05_Caregiver ;
    hi:hasInteractionIntentConcept hint:GuideIntent ;
    hi:hasInteractionModalityConcept hint:VoiceChatModality .

inst:HHAI2025 a hi:Conference ;
    rdfs:label "HHAI 2025" ;
    hi:hasConferenceName "HHAI 2025"^^xsd:string ;
    hi:hasConferenceYear "2025"^^xsd:gYear .

inst:Keyword_AutonomousSystems a skos:Concept ;
    skos:inScheme hint:HIScheme ;
    skos:prefLabel "Autonomous Systems"@en .

inst:Keyword_EthicalTrust a skos:Concept ;
    skos:inScheme hint:HIScheme ;
    skos:prefLabel "Ethical Trust"@en .

inst:Keyword_HybridAutonomy a skos:Concept ;
    skos:inScheme hint:HIScheme ;
    skos:prefLabel "Hybrid Autonomy"@en .

inst:Paper_05_Author1 a hi:Author ;
    foaf:name "Beatrice Melis" ;
    hi:hasAffiliation inst:Affiliation_UniversityOfPisaItaly ;
    hi:hasAuthorName "Beatrice Melis"^^xsd:string .

inst:Paper_05_Author2 a hi:Author ;
    foaf:name "Martina De Sanctis" ;
    hi:hasAffiliation inst:Affiliation_GranSassoScienceInstituteGssiLaquilaItaly ;
    hi:hasAuthorName "Martina De Sanctis"^^xsd:string .

inst:Paper_05_Author3 a hi:Author ;
    foaf:name "Paola Inverardi" ;
    hi:hasAffiliation inst:Affiliation_GranSassoScienceInstituteGssiLaquilaItaly ;
    hi:hasAuthorName "Paola Inverardi"^^xsd:string .

inst:Paper_05_Author4 a hi:Author ;
    foaf:name "Alessio Malizia" ;
    hi:hasAffiliation inst:Affiliation_UniversityOfPisaItaly ;
    hi:hasAuthorName "Alessio Malizia"^^xsd:string .

inst:Paper_05_Caregiver_Cap_FeedbackProvision a hi:Capability ;
    rdfs:label "Feedback Provision" ;
    hi:hasCapabilityConcept hint:ReportingCapability .

inst:Paper_05_Context a hi:Context ;
    rdfs:label "Nursing Home Assistance" ;
    hi:hasConstraintConcept hint:EthicalConstraint,
        hint:PrivacyConstraint ;
    hi:hasContextConcept hint:HealthMonitoringContext ;
    hi:hasInfluenceOn inst:Paper_05_Team ;
    hi:hasPhenomenonConcept hint:SkillsComplementarityPhenomenon,
        hint:TrustShiftPhenomenon .

inst:Paper_05_Exec_AutonomyAdjustmentExecution a hi:TaskExecution ;
    rdfs:label "Autonomy Adjustment Execution" ;
    hi:evaluatedBy inst:Paper_05_Evaluation ;
    hi:hasMethodConcept hint:ReinforcementLearningMethod ;
    hi:realizesTask inst:Paper_05_Task_AdjustAutonomyLevel .

inst:Paper_05_Exec_HygieneTaskExecution a hi:TaskExecution ;
    rdfs:label "Hygiene Task Execution" ;
    hi:evaluatedBy inst:Paper_05_Evaluation ;
    hi:hasMethodConcept hint:DataCollectionMethod ;
    hi:realizesTask inst:Paper_05_Task_PerformHygieneTasks .

inst:Paper_05_Experiment_TrustAdaptabilityExperiment a hi:Experiment ;
    rdfs:label "Trust Adaptability Experiment" ;
    hi:hasAlternativeHypothesis "Adaptive autonomy positively affects trust levels."^^xsd:string ;
    hi:hasExperimentConcept hint:TransparencyTrustExperiment ;
    hi:hasMetricTested hint:TrustPreservationMetric ;
    hi:hasNullHypothesis "Adaptive autonomy does not affect trust levels."^^xsd:string .

inst:Paper_05_Goal_RespectPatientPreferences a hi:Goal ;
    rdfs:label "Respect Patient Preferences" ;
    hi:hasGoalConcept hint:UserWellbeingGoal ;
    hi:requiresTask inst:Paper_05_Task_AdjustAutonomyLevel,
        inst:Paper_05_Task_GuidePatient,
        inst:Paper_05_Task_MonitorPatientAutonomy,
        inst:Paper_05_Task_PerformHygieneTasks .

inst:Paper_05_UseCase a hi:ResearchUseCase ;
    rdfs:label "Adaptive Autonomy in Nursing Home" ;
    hi:hasDomainConcept hint:HealthAndLifestyleDomain ;
    hi:hasHITeam inst:Paper_05_Team .

inst:Affiliation_GranSassoScienceInstituteGssiLaquilaItaly a hi:Affiliation ;
    rdfs:label "Gran Sasso Science Institute (GSSI), L’Aquila, Italy" ;
    schema1:name "Gran Sasso Science Institute (GSSI), L’Aquila, Italy" .

inst:Affiliation_UniversityOfPisaItaly a hi:Affiliation ;
    rdfs:label "University of Pisa, Italy" ;
    schema1:name "University of Pisa, Italy" .

inst:Paper_05_AssistiveRobot a hi:ArtificialAgent ;
    rdfs:label "Assistive Robot" ;
    hi:hasCapability inst:Paper_05_AssistiveRobot_Cap_AdaptiveAutonomy,
        inst:Paper_05_AssistiveRobot_Cap_TaskExecution,
        inst:Paper_05_AssistiveRobot_Cap_VerbalGuidance ;
    hi:hasRoleConcept hint:AIAssistantRole ;
    hi:performsExecution inst:Paper_05_Exec_AutonomyAdjustmentExecution,
        inst:Paper_05_Exec_HygieneTaskExecution .

inst:Paper_05_AssistiveRobot_Cap_AdaptiveAutonomy a hi:Capability ;
    rdfs:label "Adaptive Autonomy" ;
    hi:allowsTask inst:Paper_05_Task_AdjustAutonomyLevel ;
    hi:hasCapabilityConcept hint:ReinforcementLearningCapability .

inst:Paper_05_AssistiveRobot_Cap_TaskExecution a hi:Capability ;
    rdfs:label "Task Execution" ;
    hi:allowsTask inst:Paper_05_Task_PerformHygieneTasks ;
    hi:hasCapabilityConcept hint:FineDexterityCapability .

inst:Paper_05_AssistiveRobot_Cap_VerbalGuidance a hi:Capability ;
    rdfs:label "Verbal Guidance" ;
    hi:allowsTask inst:Paper_05_Task_GuidePatient ;
    hi:hasCapabilityConcept hint:ExplainingCapability .

inst:Paper_05_Caregiver a hi:HumanAgent ;
    rdfs:label "Caregiver" ;
    hi:hasCapability inst:Paper_05_Caregiver_Cap_EthicalOversight,
        inst:Paper_05_Caregiver_Cap_FeedbackProvision ;
    hi:hasRoleConcept hint:HumanUserRole .

inst:Paper_05_Caregiver_Cap_EthicalOversight a hi:Capability ;
    rdfs:label "Ethical Oversight" ;
    hi:allowsTask inst:Paper_05_Task_MonitorPatientAutonomy ;
    hi:hasCapabilityConcept hint:ClinicalJudgmentCapability .

inst:Paper_05_Evaluation a hi:Evaluation ;
    rdfs:label "Trust and Ethical Adaptability Evaluation" ;
    hi:hasEvaluationConcept hint:TransparencyEvaluation ;
    hi:hasExperiment inst:Paper_05_Experiment_TrustAdaptabilityExperiment ;
    hi:hasMetricConcept hint:TrustPreservationMetric,
        hint:UserComfortMetric .

inst:Paper_05_Task_GuidePatient a hi:Task ;
    rdfs:label "Guide Patient" ;
    hi:hasTaskConcept hint:ExplanationTask ;
    hi:requiresCapability inst:Paper_05_AssistiveRobot_Cap_VerbalGuidance .

inst:Paper_05_Task_MonitorPatientAutonomy a hi:Task ;
    rdfs:label "Monitor Patient Autonomy" ;
    hi:hasTaskConcept hint:SituationalAssessmentTask ;
    hi:requiresCapability inst:Paper_05_Caregiver_Cap_EthicalOversight .

inst:Paper_05_Team a hi:HITeam ;
    rdfs:label "Adaptive Autonomy in Nursing Home Team" ;
    hi:hasGoal inst:Paper_05_Goal_RespectPatientPreferences ;
    hi:hasMember inst:Paper_05_AssistiveRobot,
        inst:Paper_05_Caregiver ;
    hi:isInfluencedBy inst:Paper_05_Context .

inst:Paper_05_Task_AdjustAutonomyLevel a hi:Task ;
    rdfs:label "Adjust Autonomy Level" ;
    hi:hasTaskConcept hint:DecideInterventionTask ;
    hi:requiresCapability inst:Paper_05_AssistiveRobot_Cap_AdaptiveAutonomy .

inst:Paper_05_Task_PerformHygieneTasks a hi:Task ;
    rdfs:label "Perform Hygiene Tasks" ;
    hi:hasTaskConcept hint:DataCollectionTask ;
    hi:requiresCapability inst:Paper_05_AssistiveRobot_Cap_TaskExecution .


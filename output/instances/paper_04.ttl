@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix hi: <https://w3id.org/hi-ontology#> .
@prefix hint: <https://w3id.org/hi-thesaurus/> .
@prefix inst: <https://w3id.org/hi-ontology/instances/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

inst:Paper_04 a hi:Paper ;
    hi:describesUseCase inst:Paper_04_UseCase ;
    hi:hasAuthor inst:Paper_04_Author1,
        inst:Paper_04_Author2,
        inst:Paper_04_Author3 ;
    hi:hasKeyword inst:Keyword_DecisionSupportSystems,
        inst:Keyword_FaceMatching,
        inst:Keyword_HumanFactors ;
    hi:hasPublicationYear "2025"^^xsd:gYear ;
    hi:hasTitle "Human Response to Decision Support in Face Matching: The Influence of Task Difficulty and Machine Accuracy"^^xsd:string ;
    hi:publishedAt inst:HHAI2025 .

inst:Paper_04_Interaction_Human-machineDecisionInteraction a hi:Interaction ;
    rdfs:label "Human-Machine Decision Interaction" ;
    hi:hasAgentInvolved inst:Paper_04_FaceMatchingSystem,
        inst:Paper_04_HumanAnnotator ;
    hi:hasInteractionIntentConcept hint:ExplanationIntent ;
    hi:hasInteractionModalityConcept hint:DashboardModality .

inst:Affiliation_UniversitatPompeuFabraIcrea a hi:Affiliation ;
    rdfs:label "Universitat Pompeu Fabra, ICREA" ;
    schema1:name "Universitat Pompeu Fabra, ICREA" .

inst:HHAI2025 a hi:Conference ;
    rdfs:label "HHAI 2025" ;
    hi:hasConferenceName "HHAI 2025"^^xsd:string ;
    hi:hasConferenceYear "2025"^^xsd:gYear .

inst:Keyword_DecisionSupportSystems a skos:Concept ;
    skos:inScheme hint:HIScheme ;
    skos:prefLabel "Decision support systems"@en .

inst:Keyword_FaceMatching a skos:Concept ;
    skos:inScheme hint:HIScheme ;
    skos:prefLabel "Face matching"@en .

inst:Keyword_HumanFactors a skos:Concept ;
    skos:inScheme hint:HIScheme ;
    skos:prefLabel "Human factors"@en .

inst:Paper_04_Author1 a hi:Author ;
    foaf:name "Marina Estevez-Almenzar" ;
    hi:hasAffiliation inst:Affiliation_UniversitatPompeuFabra ;
    hi:hasAuthorName "Marina Estevez-Almenzar"^^xsd:string .

inst:Paper_04_Author2 a hi:Author ;
    foaf:name "Ricardo Baeza-Yates" ;
    hi:hasAffiliation inst:Affiliation_UniversitatPompeuFabra ;
    hi:hasAuthorName "Ricardo Baeza-Yates"^^xsd:string .

inst:Paper_04_Author3 a hi:Author ;
    foaf:name "Carlos Castillo" ;
    hi:hasAffiliation inst:Affiliation_UniversitatPompeuFabraIcrea ;
    hi:hasAuthorName "Carlos Castillo"^^xsd:string .

inst:Paper_04_Context a hi:Context ;
    rdfs:label "Face Matching Context" ;
    hi:hasConstraintConcept hint:EthicalConstraint,
        hint:TransparencyConstraint ;
    hi:hasContextConcept hint:JuryDeliberationContext ;
    hi:hasInfluenceOn inst:Paper_04_Team ;
    hi:hasPhenomenonConcept hint:ConfirmationBias,
        hint:TrustShiftPhenomenon .

inst:Paper_04_Exec_HumanEvaluatesFacePair a hi:TaskExecution ;
    rdfs:label "Human Evaluates Face Pair" ;
    hi:evaluatedBy inst:Paper_04_Evaluation ;
    hi:hasMethodConcept hint:DataCollectionMethod ;
    hi:realizesTask inst:Paper_04_Task_EvaluateFacePair .

inst:Paper_04_Exec_SystemProvidesSuggestion a hi:TaskExecution ;
    rdfs:label "System Provides Suggestion" ;
    hi:evaluatedBy inst:Paper_04_Evaluation ;
    hi:hasMethodConcept hint:PatternLearningCapability ;
    hi:realizesTask inst:Paper_04_Task_ProvideMatchingSuggestion .

inst:Paper_04_Experiment_ImpactOfMachineAccuracyOnHumanPerformance a hi:Experiment ;
    rdfs:label "Impact of Machine Accuracy on Human Performance" ;
    hi:hasAlternativeHypothesis "Machine accuracy affects human performance."^^xsd:string ;
    hi:hasExperimentConcept hint:DeliberationSupportExperiment ;
    hi:hasMetricTested hint:TaskSuccessRateMetric ;
    hi:hasNullHypothesis "Machine accuracy does not affect human performance."^^xsd:string .

inst:Paper_04_Goal_ImproveFaceMatchingAccuracy a hi:Goal ;
    rdfs:label "Improve Face Matching Accuracy" ;
    hi:hasGoalConcept hint:FairAccurateVerdictGoal ;
    hi:requiresTask inst:Paper_04_Task_EvaluateFacePair,
        inst:Paper_04_Task_ProvideMatchingSuggestion .

inst:Paper_04_UseCase a hi:ResearchUseCase ;
    rdfs:label "Face Matching Decision Support" ;
    hi:hasDomainConcept hint:LawAndPolicyDomain ;
    hi:hasHITeam inst:Paper_04_Team .

inst:Affiliation_UniversitatPompeuFabra a hi:Affiliation ;
    rdfs:label "Universitat Pompeu Fabra" ;
    schema1:name "Universitat Pompeu Fabra" .

inst:Paper_04_Evaluation a hi:Evaluation ;
    rdfs:label "Face Matching System Evaluation" ;
    hi:hasEvaluationConcept hint:AIInterventionImpactEvaluation ;
    hi:hasExperiment inst:Paper_04_Experiment_ImpactOfMachineAccuracyOnHumanPerformance ;
    hi:hasMetricConcept hint:TaskSuccessRateMetric,
        hint:TrustPreservationMetric .

inst:Paper_04_FaceMatchingSystem a hi:ArtificialAgent ;
    rdfs:label "Face Matching System" ;
    hi:hasCapability inst:Paper_04_FaceMatchingSystem_Cap_AccuracyReporting,
        inst:Paper_04_FaceMatchingSystem_Cap_PatternRecognition ;
    hi:hasRoleConcept hint:AIAssistantRole ;
    hi:performsExecution inst:Paper_04_Exec_SystemProvidesSuggestion .

inst:Paper_04_FaceMatchingSystem_Cap_AccuracyReporting a hi:Capability ;
    rdfs:label "Accuracy Reporting" ;
    hi:allowsTask inst:Paper_04_Task_ProvideMatchingSuggestion ;
    hi:hasCapabilityConcept hint:ReportingCapability .

inst:Paper_04_FaceMatchingSystem_Cap_PatternRecognition a hi:Capability ;
    rdfs:label "Pattern Recognition" ;
    hi:allowsTask inst:Paper_04_Task_ProvideMatchingSuggestion ;
    hi:hasCapabilityConcept hint:PatternLearningCapability .

inst:Paper_04_HumanAnnotator a hi:HumanAgent ;
    rdfs:label "Human Annotator" ;
    hi:hasCapability inst:Paper_04_HumanAnnotator_Cap_JudgmentCapability,
        inst:Paper_04_HumanAnnotator_Cap_PerceptionCapability ;
    hi:hasRoleConcept hint:HumanUserRole ;
    hi:performsExecution inst:Paper_04_Exec_HumanEvaluatesFacePair .

inst:Paper_04_HumanAnnotator_Cap_JudgmentCapability a hi:Capability ;
    rdfs:label "Judgment Capability" ;
    hi:allowsTask inst:Paper_04_Task_EvaluateFacePair ;
    hi:hasCapabilityConcept hint:ReasoningCapability .

inst:Paper_04_HumanAnnotator_Cap_PerceptionCapability a hi:Capability ;
    rdfs:label "Perception Capability" ;
    hi:allowsTask inst:Paper_04_Task_EvaluateFacePair ;
    hi:hasCapabilityConcept hint:SensingCapability .

inst:Paper_04_Team a hi:HITeam ;
    rdfs:label "Face Matching Decision Support Team" ;
    hi:hasGoal inst:Paper_04_Goal_ImproveFaceMatchingAccuracy ;
    hi:hasMember inst:Paper_04_FaceMatchingSystem,
        inst:Paper_04_HumanAnnotator ;
    hi:isInfluencedBy inst:Paper_04_Context .

inst:Paper_04_Task_EvaluateFacePair a hi:Task ;
    rdfs:label "Evaluate Face Pair" ;
    hi:hasTaskConcept hint:DataCollectionTask ;
    hi:requiresCapability inst:Paper_04_HumanAnnotator_Cap_JudgmentCapability,
        inst:Paper_04_HumanAnnotator_Cap_PerceptionCapability .

inst:Paper_04_Task_ProvideMatchingSuggestion a hi:Task ;
    rdfs:label "Provide Matching Suggestion" ;
    hi:hasTaskConcept hint:ExplanationTask ;
    hi:requiresCapability inst:Paper_04_FaceMatchingSystem_Cap_AccuracyReporting,
        inst:Paper_04_FaceMatchingSystem_Cap_PatternRecognition .


@prefix hi: <https://w3id.org/hi-ontology#> .
@prefix hint: <https://w3id.org/hi-thesaurus/> .
@prefix inst: <https://w3id.org/hi-ontology/instances/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

inst:Scenario_01_Interaction_ExplanationExchange a hi:Interaction ;
    rdfs:label "Explanation Exchange" ;
    hi:hasAgentInvolved inst:Scenario_01_AiSecuritySystem,
        inst:Scenario_01_CybersecurityExpert ;
    hi:hasInteractionIntentConcept hint:ExplanationIntent ;
    hi:hasInteractionModalityConcept hint:DashboardModality .

inst:Scenario_01_UseCase a hi:CompetitionUseCase ;
    rdfs:label "Cybersecurity Response for Voting System" ;
    hi:hasDomainConcept hint:LawAndPolicyDomain ;
    hi:hasHITeam inst:Scenario_01_Team ;
    hi:hasScenarioDescription "Cybersecurity Context"^^xsd:string .

inst:Scenario_01_AiSecuritySystem_Cap_PredictionMaking a hi:Capability ;
    rdfs:label "Prediction Making" ;
    hi:hasCapabilityConcept hint:BayesianReasoningCapability .

inst:Scenario_01_Context a hi:Context ;
    rdfs:label "Cybersecurity Context" ;
    hi:hasConstraintConcept hint:SafetyConstraint,
        hint:TransparencyConstraint ;
    hi:hasContextConcept hint:WorkspaceManipulationContext ;
    hi:hasInfluenceOn inst:Scenario_01_Team ;
    hi:hasPhenomenonConcept hint:SkillsComplementarityPhenomenon,
        hint:TrustShiftPhenomenon .

inst:Scenario_01_CybersecurityExpert_Cap_CommunicationClarity a hi:Capability ;
    rdfs:label "Communication Clarity" ;
    hi:hasCapabilityConcept hint:ExplainingCapability .

inst:Scenario_01_Exec_AiBlocksIps a hi:TaskExecution ;
    rdfs:label "AI Blocks IPs" ;
    hi:evaluatedBy inst:Scenario_01_Evaluation ;
    hi:hasMethodConcept hint:PatternLearningCapability ;
    hi:realizesTask inst:Scenario_01_Task_BlockSuspectedIps .

inst:Scenario_01_Exec_HumanUnblocksIps a hi:TaskExecution ;
    rdfs:label "Human Unblocks IPs" ;
    hi:evaluatedBy inst:Scenario_01_Evaluation ;
    hi:hasMethodConcept hint:ReasoningCapability ;
    hi:realizesTask inst:Scenario_01_Task_UnblockIps .

inst:Scenario_01_Experiment_TrustAndEffectivenessExperiment a hi:Experiment ;
    rdfs:label "Trust and Effectiveness Experiment" ;
    hi:hasAlternativeHypothesis "The system improves response time and trust."^^xsd:string ;
    hi:hasExperimentConcept hint:DeliberationSupportExperiment ;
    hi:hasMetricTested hint:TaskSuccessRateMetric,
        hint:TrustPreservationMetric ;
    hi:hasNullHypothesis "The system does not improve response time."^^xsd:string .

inst:Scenario_01_Goal_EnsureVotingSystemSecurity a hi:Goal ;
    rdfs:label "Ensure Voting System Security" ;
    hi:hasGoalConcept hint:SafeRetrievalGoal ;
    hi:requiresTask inst:Scenario_01_Task_BlockSuspectedIps,
        inst:Scenario_01_Task_Cross-checkPredictions,
        inst:Scenario_01_Task_ProvideFeedback,
        inst:Scenario_01_Task_UnblockIps .

inst:Scenario_01_AiSecuritySystem a hi:ArtificialAgent ;
    rdfs:label "AI Security System" ;
    hi:hasCapability inst:Scenario_01_AiSecuritySystem_Cap_ExplanationGeneration,
        inst:Scenario_01_AiSecuritySystem_Cap_IpBlocking,
        inst:Scenario_01_AiSecuritySystem_Cap_PredictionMaking ;
    hi:hasRoleConcept hint:AIAssistantRole ;
    hi:performsExecution inst:Scenario_01_Exec_AiBlocksIps .

inst:Scenario_01_AiSecuritySystem_Cap_ExplanationGeneration a hi:Capability ;
    rdfs:label "Explanation Generation" ;
    hi:allowsTask inst:Scenario_01_Task_ProvideFeedback ;
    hi:hasCapabilityConcept hint:ExplainingCapability .

inst:Scenario_01_AiSecuritySystem_Cap_IpBlocking a hi:Capability ;
    rdfs:label "IP Blocking" ;
    hi:allowsTask inst:Scenario_01_Task_BlockSuspectedIps ;
    hi:hasCapabilityConcept hint:PatternLearningCapability .

inst:Scenario_01_CybersecurityExpert a hi:HumanAgent ;
    rdfs:label "Cybersecurity Expert" ;
    hi:hasCapability inst:Scenario_01_CybersecurityExpert_Cap_CommunicationClarity,
        inst:Scenario_01_CybersecurityExpert_Cap_ContextualUnderstanding,
        inst:Scenario_01_CybersecurityExpert_Cap_DecisionMaking ;
    hi:hasRoleConcept hint:RiskOperatorRole ;
    hi:performsExecution inst:Scenario_01_Exec_HumanUnblocksIps .

inst:Scenario_01_CybersecurityExpert_Cap_ContextualUnderstanding a hi:Capability ;
    rdfs:label "Contextual Understanding" ;
    hi:allowsTask inst:Scenario_01_Task_Cross-checkPredictions ;
    hi:hasCapabilityConcept hint:SituationalAwarenessCapability .

inst:Scenario_01_CybersecurityExpert_Cap_DecisionMaking a hi:Capability ;
    rdfs:label "Decision Making" ;
    hi:allowsTask inst:Scenario_01_Task_UnblockIps ;
    hi:hasCapabilityConcept hint:ReasoningCapability .

inst:Scenario_01_Evaluation a hi:Evaluation ;
    rdfs:label "System Effectiveness Evaluation" ;
    hi:hasEvaluationConcept hint:AIInterventionImpactEvaluation ;
    hi:hasExperiment inst:Scenario_01_Experiment_TrustAndEffectivenessExperiment ;
    hi:hasMetricConcept hint:TaskSuccessRateMetric,
        hint:TrustPreservationMetric .

inst:Scenario_01_Task_Cross-checkPredictions a hi:Task ;
    rdfs:label "Cross-check Predictions" ;
    hi:hasTaskConcept hint:SemanticReasoningTask ;
    hi:requiresCapability inst:Scenario_01_CybersecurityExpert_Cap_ContextualUnderstanding .

inst:Scenario_01_Task_ProvideFeedback a hi:Task ;
    rdfs:label "Provide Feedback" ;
    hi:hasTaskConcept hint:ExplanationTask ;
    hi:requiresCapability inst:Scenario_01_AiSecuritySystem_Cap_ExplanationGeneration .

inst:Scenario_01_Team a hi:HITeam ;
    rdfs:label "Cybersecurity Response for Voting System Team" ;
    hi:hasGoal inst:Scenario_01_Goal_EnsureVotingSystemSecurity ;
    hi:hasMember inst:Scenario_01_AiSecuritySystem,
        inst:Scenario_01_CybersecurityExpert ;
    hi:isInfluencedBy inst:Scenario_01_Context .

inst:Scenario_01_Task_BlockSuspectedIps a hi:Task ;
    rdfs:label "Block Suspected IPs" ;
    hi:hasTaskConcept hint:DataCollectionTask ;
    hi:requiresCapability inst:Scenario_01_AiSecuritySystem_Cap_IpBlocking .

inst:Scenario_01_Task_UnblockIps a hi:Task ;
    rdfs:label "Unblock IPs" ;
    hi:hasTaskConcept hint:ConflictResolutionTask ;
    hi:requiresCapability inst:Scenario_01_CybersecurityExpert_Cap_DecisionMaking .


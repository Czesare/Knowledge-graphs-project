@prefix hi: <https://w3id.org/hi-ontology#> .
@prefix hint: <https://w3id.org/hi-thesaurus/> .
@prefix inst: <https://w3id.org/hi-ontology/instances/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

inst:Scenario_03_Interaction_Teacher-robotInteraction a hi:Interaction ;
    rdfs:label "Teacher-Robot Interaction" ;
    hi:hasAgentInvolved inst:Scenario_03_Leah,
        inst:Scenario_03_NaoRobot ;
    hi:hasInteractionIntentConcept hint:GuideIntent ;
    hi:hasInteractionModalityConcept hint:VerbalDialogueModality .

inst:Scenario_03_UseCase a hi:CompetitionUseCase ;
    rdfs:label "Child Education Intervention" ;
    hi:hasDomainConcept hint:EducationDomain ;
    hi:hasHITeam inst:Scenario_03_Team ;
    hi:hasScenarioDescription "School Intervention Context"^^xsd:string .

inst:Scenario_03_Anna a hi:HumanAgent ;
    rdfs:label "Anna" ;
    hi:hasCapability inst:Scenario_03_Anna_Cap_BehavioristApproach,
        inst:Scenario_03_Anna_Cap_ExpertPosition ;
    hi:hasRoleConcept hint:ClinicianRole .

inst:Scenario_03_Context a hi:Context ;
    rdfs:label "School Intervention Context" ;
    hi:hasConstraintConcept hint:AutonomyConstraint,
        hint:TransparencyConstraint ;
    hi:hasContextConcept hint:OnlineLearningContext ;
    hi:hasInfluenceOn inst:Scenario_03_Team ;
    hi:hasPhenomenonConcept hint:KnowledgeMismatchPhenomenon,
        hint:SkillsComplementarityPhenomenon .

inst:Scenario_03_Exec_LeahsTaskPlanning a hi:TaskExecution ;
    rdfs:label "Leah's Task Planning" ;
    hi:evaluatedBy inst:Scenario_03_Evaluation ;
    hi:hasMethodConcept hint:CooperativeLearningMethod ;
    hi:realizesTask inst:Scenario_03_Task_TaskPlanningTask .

inst:Scenario_03_Exec_NaoInteractiveSession a hi:TaskExecution ;
    rdfs:label "NAO Interactive Session" ;
    hi:evaluatedBy inst:Scenario_03_Evaluation ;
    hi:hasMethodConcept hint:VirtualRealityInputParsingMethod ;
    hi:realizesTask inst:Scenario_03_Task_RobotInteractionTask .

inst:Scenario_03_Experiment_LearningOutcomeExperiment a hi:Experiment ;
    rdfs:label "Learning Outcome Experiment" ;
    hi:hasAlternativeHypothesis "The intervention improves learning outcomes."^^xsd:string ;
    hi:hasExperimentConcept hint:OnlineTutoringExperiment ;
    hi:hasMetricTested hint:LearningGainMetric ;
    hi:hasNullHypothesis "The intervention does not improve learning outcomes."^^xsd:string .

inst:Scenario_03_Goal_ImproveLearningOutcomes a hi:Goal ;
    rdfs:label "Improve Learning Outcomes" ;
    hi:hasGoalConcept hint:EffectiveLearningGoal ;
    hi:requiresTask inst:Scenario_03_Task_BehaviorTrainingTask,
        inst:Scenario_03_Task_CoordinatedActionTask,
        inst:Scenario_03_Task_GuidanceTask,
        inst:Scenario_03_Task_RobotInteractionTask,
        inst:Scenario_03_Task_TaskPlanningTask .

inst:Scenario_03_Leah_Cap_TechnologyEnthusiasm a hi:Capability ;
    rdfs:label "Technology Enthusiasm" ;
    hi:hasCapabilityConcept hint:PatternLearningCapability .

inst:Scenario_03_Anna_Cap_BehavioristApproach a hi:Capability ;
    rdfs:label "Behaviorist Approach" ;
    hi:allowsTask inst:Scenario_03_Task_BehaviorTrainingTask ;
    hi:hasCapabilityConcept hint:ClinicalJudgmentCapability .

inst:Scenario_03_Anna_Cap_ExpertPosition a hi:Capability ;
    rdfs:label "Expert Position" ;
    hi:allowsTask inst:Scenario_03_Task_GuidanceTask ;
    hi:hasCapabilityConcept hint:ExplainingCapability .

inst:Scenario_03_Evaluation a hi:Evaluation ;
    rdfs:label "Intervention Outcome Evaluation" ;
    hi:hasEvaluationConcept hint:TutorImpactEvaluation ;
    hi:hasExperiment inst:Scenario_03_Experiment_LearningOutcomeExperiment ;
    hi:hasMetricConcept hint:LearningGainMetric .

inst:Scenario_03_Leah a hi:HumanAgent ;
    rdfs:label "Leah" ;
    hi:hasCapability inst:Scenario_03_Leah_Cap_PedagogicalJudgment,
        inst:Scenario_03_Leah_Cap_TechnologyEnthusiasm ;
    hi:hasRoleConcept hint:TutorRole ;
    hi:performsExecution inst:Scenario_03_Exec_LeahsTaskPlanning .

inst:Scenario_03_Leah_Cap_PedagogicalJudgment a hi:Capability ;
    rdfs:label "Pedagogical Judgment" ;
    hi:allowsTask inst:Scenario_03_Task_TaskPlanningTask ;
    hi:hasCapabilityConcept hint:ReasoningCapability .

inst:Scenario_03_NaoRobot a hi:ArtificialAgent ;
    rdfs:label "NAO Robot" ;
    hi:hasCapability inst:Scenario_03_NaoRobot_Cap_ReactiveResponse,
        inst:Scenario_03_NaoRobot_Cap_WizardOfOzParadigm ;
    hi:hasRoleConcept hint:AIAssistantRole ;
    hi:performsExecution inst:Scenario_03_Exec_NaoInteractiveSession .

inst:Scenario_03_NaoRobot_Cap_ReactiveResponse a hi:Capability ;
    rdfs:label "Reactive Response" ;
    hi:allowsTask inst:Scenario_03_Task_RobotInteractionTask ;
    hi:hasCapabilityConcept hint:SensingCapability .

inst:Scenario_03_NaoRobot_Cap_WizardOfOzParadigm a hi:Capability ;
    rdfs:label "Wizard of Oz Paradigm" ;
    hi:allowsTask inst:Scenario_03_Task_CoordinatedActionTask ;
    hi:hasCapabilityConcept hint:OperatorCoordinationCapability .

inst:Scenario_03_Task_BehaviorTrainingTask a hi:Task ;
    rdfs:label "Behavior Training Task" ;
    hi:hasTaskConcept hint:DecideInterventionTask ;
    hi:requiresCapability inst:Scenario_03_Anna_Cap_BehavioristApproach .

inst:Scenario_03_Task_CoordinatedActionTask a hi:Task ;
    rdfs:label "Coordinated Action Task" ;
    hi:hasTaskConcept hint:OperatorCoordinationTask ;
    hi:requiresCapability inst:Scenario_03_NaoRobot_Cap_WizardOfOzParadigm .

inst:Scenario_03_Task_GuidanceTask a hi:Task ;
    rdfs:label "Guidance Task" ;
    hi:hasTaskConcept hint:ExplanationTask ;
    hi:requiresCapability inst:Scenario_03_Anna_Cap_ExpertPosition .

inst:Scenario_03_Team a hi:HITeam ;
    rdfs:label "Child Education Intervention Team" ;
    hi:hasGoal inst:Scenario_03_Goal_ImproveLearningOutcomes ;
    hi:hasMember inst:Scenario_03_Anna,
        inst:Scenario_03_Leah,
        inst:Scenario_03_NaoRobot ;
    hi:isInfluencedBy inst:Scenario_03_Context .

inst:Scenario_03_Task_RobotInteractionTask a hi:Task ;
    rdfs:label "Robot Interaction Task" ;
    hi:hasTaskConcept hint:MultimodalInputInterpretationTask ;
    hi:requiresCapability inst:Scenario_03_NaoRobot_Cap_ReactiveResponse .

inst:Scenario_03_Task_TaskPlanningTask a hi:Task ;
    rdfs:label "Task Planning Task" ;
    hi:hasTaskConcept hint:PolicyLearningTask ;
    hi:requiresCapability inst:Scenario_03_Leah_Cap_PedagogicalJudgment .


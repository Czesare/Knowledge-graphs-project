@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix hi: <https://w3id.org/hi-ontology#> .
@prefix hint: <https://w3id.org/hi-thesaurus/> .
@prefix inst: <https://w3id.org/hi-ontology/instances/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

inst:Paper_06 a hi:Paper ;
    hi:describesUseCase inst:Paper_06_UseCase ;
    hi:hasAuthor inst:Paper_06_Author1,
        inst:Paper_06_Author2,
        inst:Paper_06_Author3 ;
    hi:hasKeyword inst:Keyword_HighQualityAi,
        inst:Keyword_Multi-headDeepLearning,
        inst:Keyword_MultimodalAi,
        inst:Keyword_RobustAi ;
    hi:hasPublicationYear "2025"^^xsd:gYear ;
    hi:hasTitle "Multi-Head Networks for Missing Modalities: A Study on Robustness in Multimodal Learning"^^xsd:string ;
    hi:publishedAt inst:HHAI2025 .

inst:Paper_06_Interaction_ModelFeedbackSession a hi:Interaction ;
    rdfs:label "Model Feedback Session" ;
    hi:hasAgentInvolved inst:Paper_06_Multi-headNetwork,
        inst:Paper_06_ResearchScientist ;
    hi:hasInteractionIntentConcept hint:ExplanationIntent ;
    hi:hasInteractionModalityConcept hint:DashboardModality .

inst:Affiliation_SpindoxSpa a hi:Affiliation ;
    rdfs:label "Spindox S.p.A." ;
    schema1:name "Spindox S.p.A." .

inst:HHAI2025 a hi:Conference ;
    rdfs:label "HHAI 2025" ;
    hi:hasConferenceName "HHAI 2025"^^xsd:string ;
    hi:hasConferenceYear "2025"^^xsd:gYear .

inst:Keyword_HighQualityAi a skos:Concept ;
    skos:inScheme hint:HIScheme ;
    skos:prefLabel "High Quality AI"@en .

inst:Keyword_Multi-headDeepLearning a skos:Concept ;
    skos:inScheme hint:HIScheme ;
    skos:prefLabel "Multi-Head Deep Learning"@en .

inst:Keyword_MultimodalAi a skos:Concept ;
    skos:inScheme hint:HIScheme ;
    skos:prefLabel "Multimodal AI"@en .

inst:Keyword_RobustAi a skos:Concept ;
    skos:inScheme hint:HIScheme ;
    skos:prefLabel "Robust AI"@en .

inst:Paper_06_Author1 a hi:Author ;
    foaf:name "Giovanni Felici" ;
    hi:hasAffiliation inst:Affiliation_InstituteForSystemsAnalysisAndComputerScienceCnrNationalResearchCouncilOfItaly ;
    hi:hasAuthorName "Giovanni Felici"^^xsd:string .

inst:Paper_06_Author2 a hi:Author ;
    foaf:name "Diego Maria Pinto" ;
    hi:hasAffiliation inst:Affiliation_InstituteForSystemsAnalysisAndComputerScienceCnrNationalResearchCouncilOfItaly ;
    hi:hasAuthorName "Diego Maria Pinto"^^xsd:string .

inst:Paper_06_Author3 a hi:Author ;
    foaf:name "Antonio Vicinanza" ;
    hi:hasAffiliation inst:Affiliation_SpindoxSpa ;
    hi:hasAuthorName "Antonio Vicinanza"^^xsd:string .

inst:Paper_06_Context a hi:Context ;
    rdfs:label "Multimodal Learning Context" ;
    hi:hasConstraintConcept hint:TransparencyConstraint ;
    hi:hasContextConcept hint:HealthMonitoringContext ;
    hi:hasInfluenceOn inst:Paper_06_Team ;
    hi:hasPhenomenonConcept hint:DataMismatchPhenomenon,
        hint:SkillsComplementarityPhenomenon .

inst:Paper_06_Exec_ExecuteAblationStudy a hi:TaskExecution ;
    rdfs:label "Execute Ablation Study" ;
    hi:evaluatedBy inst:Paper_06_Evaluation ;
    hi:hasMethodConcept hint:MetaAnalysisScoringMethod ;
    hi:realizesTask inst:Paper_06_Task_ConductAblationStudy .

inst:Paper_06_Exec_ExecuteFeatureExtraction a hi:TaskExecution ;
    rdfs:label "Execute Feature Extraction" ;
    hi:evaluatedBy inst:Paper_06_Evaluation ;
    hi:hasMethodConcept hint:DataCollectionMethod ;
    hi:realizesTask inst:Paper_06_Task_FeatureExtraction .

inst:Paper_06_Exec_ExecuteOrthogonalityLossApplication a hi:TaskExecution ;
    rdfs:label "Execute Orthogonality Loss Application" ;
    hi:evaluatedBy inst:Paper_06_Evaluation ;
    hi:hasMethodConcept hint:SemanticLinkingMethod ;
    hi:realizesTask inst:Paper_06_Task_ApplyOrthogonalityLoss .

inst:Paper_06_Experiment_AblationStudyExperiment a hi:Experiment ;
    rdfs:label "Ablation Study Experiment" ;
    hi:hasAlternativeHypothesis "Orthogonality loss improves robustness."^^xsd:string ;
    hi:hasExperimentConcept hint:DiagnosisExperiment ;
    hi:hasMetricTested hint:DiagnosisAccuracyMetric ;
    hi:hasNullHypothesis "Orthogonality loss does not improve robustness."^^xsd:string .

inst:Paper_06_Goal_EnhanceModelRobustness a hi:Goal ;
    rdfs:label "Enhance Model Robustness" ;
    hi:hasGoalConcept hint:UserWellbeingGoal ;
    hi:requiresTask inst:Paper_06_Task_ApplyOrthogonalityLoss,
        inst:Paper_06_Task_ConductAblationStudy,
        inst:Paper_06_Task_FeatureExtraction .

inst:Paper_06_Multi-headNetwork_Cap_Classification a hi:Capability ;
    rdfs:label "Classification" ;
    hi:hasCapabilityConcept hint:ReasoningCapability .

inst:Paper_06_Multi-headNetwork_Cap_RobustnessEnhancement a hi:Capability ;
    rdfs:label "Robustness Enhancement" ;
    hi:hasCapabilityConcept hint:ReinforcementLearningCapability .

inst:Paper_06_ResearchScientist_Cap_FeedbackProvision a hi:Capability ;
    rdfs:label "Feedback Provision" ;
    hi:hasCapabilityConcept hint:ExplainingCapability .

inst:Paper_06_UseCase a hi:ResearchUseCase ;
    rdfs:label "Robust Multimodal Learning" ;
    hi:hasDomainConcept hint:HealthAndLifestyleDomain ;
    hi:hasHITeam inst:Paper_06_Team .

inst:Affiliation_InstituteForSystemsAnalysisAndComputerScienceCnrNationalResearchCouncilOfItaly a hi:Affiliation ;
    rdfs:label "Institute for Systems Analysis and Computer Science CNR, National Research Council of Italy" ;
    schema1:name "Institute for Systems Analysis and Computer Science CNR, National Research Council of Italy" .

inst:Paper_06_Multi-headNetwork a hi:ArtificialAgent ;
    rdfs:label "Multi-Head Network" ;
    hi:hasCapability inst:Paper_06_Multi-headNetwork_Cap_Classification,
        inst:Paper_06_Multi-headNetwork_Cap_FeatureExtraction,
        inst:Paper_06_Multi-headNetwork_Cap_RobustnessEnhancement ;
    hi:hasRoleConcept hint:AIAssistantRole ;
    hi:performsExecution inst:Paper_06_Exec_ExecuteFeatureExtraction,
        inst:Paper_06_Exec_ExecuteOrthogonalityLossApplication .

inst:Paper_06_Multi-headNetwork_Cap_FeatureExtraction a hi:Capability ;
    rdfs:label "Feature Extraction" ;
    hi:allowsTask inst:Paper_06_Task_FeatureExtraction ;
    hi:hasCapabilityConcept hint:PatternLearningCapability .

inst:Paper_06_ResearchScientist a hi:HumanAgent ;
    rdfs:label "Research Scientist" ;
    hi:hasCapability inst:Paper_06_ResearchScientist_Cap_DomainJudgment,
        inst:Paper_06_ResearchScientist_Cap_FeedbackProvision ;
    hi:hasRoleConcept hint:HumanUserRole ;
    hi:performsExecution inst:Paper_06_Exec_ExecuteAblationStudy .

inst:Paper_06_Task_ApplyOrthogonalityLoss a hi:Task ;
    rdfs:label "Apply Orthogonality Loss" ;
    hi:hasTaskConcept hint:SemanticReasoningTask ;
    hi:requiresCapability inst:Paper_06_ResearchScientist_Cap_DomainJudgment .

inst:Paper_06_Task_ConductAblationStudy a hi:Task ;
    rdfs:label "Conduct Ablation Study" ;
    hi:hasTaskConcept hint:HypothesisComparisonTask ;
    hi:requiresCapability inst:Paper_06_ResearchScientist_Cap_DomainJudgment .

inst:Paper_06_Team a hi:HITeam ;
    rdfs:label "Robust Multimodal Learning Team" ;
    hi:hasGoal inst:Paper_06_Goal_EnhanceModelRobustness ;
    hi:hasMember inst:Paper_06_Multi-headNetwork,
        inst:Paper_06_ResearchScientist ;
    hi:isInfluencedBy inst:Paper_06_Context .

inst:Paper_06_Evaluation a hi:Evaluation ;
    rdfs:label "Model Robustness Evaluation" ;
    hi:hasEvaluationConcept hint:AIInterventionImpactEvaluation ;
    hi:hasExperiment inst:Paper_06_Experiment_AblationStudyExperiment ;
    hi:hasMetricConcept hint:DiagnosisAccuracyMetric,
        hint:TaskSuccessRateMetric .

inst:Paper_06_ResearchScientist_Cap_DomainJudgment a hi:Capability ;
    rdfs:label "Domain Judgment" ;
    hi:hasCapabilityConcept hint:ClinicalJudgmentCapability .

inst:Paper_06_Task_FeatureExtraction a hi:Task ;
    rdfs:label "Feature Extraction" ;
    hi:hasTaskConcept hint:DataCollectionTask ;
    hi:requiresCapability inst:Paper_06_Multi-headNetwork_Cap_FeatureExtraction .


@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix hi: <https://w3id.org/hi-ontology#> .
@prefix hint: <https://w3id.org/hi-thesaurus/> .
@prefix inst: <https://w3id.org/hi-ontology/instances/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

inst:Paper_08 a hi:Paper ;
    hi:describesUseCase inst:Paper_08_UseCase ;
    hi:hasAuthor inst:Paper_08_Author1,
        inst:Paper_08_Author2 ;
    hi:hasKeyword inst:Keyword_ActiveLearning,
        inst:Keyword_InformationQuality,
        inst:Keyword_SituationalAwareness ;
    hi:hasPublicationYear "2025"^^xsd:gYear ;
    hi:hasTitle "Quality-Informed Active Learning on Social Media in Crisis Scenarios"^^xsd:string ;
    hi:publishedAt inst:HHAI2025 .

inst:Paper_08_Interaction_Analyst-systemDialogue a hi:Interaction ;
    rdfs:label "Analyst-System Dialogue" ;
    hi:hasAgentInvolved inst:Paper_08_ActiveLearningSystem,
        inst:Paper_08_CrisisAnalyst ;
    hi:hasInteractionIntentConcept hint:ExplanationIntent ;
    hi:hasInteractionModalityConcept hint:TextChatModality .

inst:HHAI2025 a hi:Conference ;
    rdfs:label "HHAI 2025" ;
    hi:hasConferenceName "HHAI 2025"^^xsd:string ;
    hi:hasConferenceYear "2025"^^xsd:gYear .

inst:Keyword_ActiveLearning a skos:Concept ;
    skos:inScheme hint:HIScheme ;
    skos:prefLabel "Active Learning"@en .

inst:Keyword_InformationQuality a skos:Concept ;
    skos:inScheme hint:HIScheme ;
    skos:prefLabel "Information Quality"@en .

inst:Keyword_SituationalAwareness a skos:Concept ;
    skos:inScheme hint:HIScheme ;
    skos:prefLabel "Situational Awareness"@en .

inst:Paper_08_ActiveLearningSystem_Cap_PatternRecognition a hi:Capability ;
    rdfs:label "Pattern Recognition" ;
    hi:hasCapabilityConcept hint:PatternLearningCapability .

inst:Paper_08_Author1 a hi:Author ;
    foaf:name "Carlo Alberto Bono" ;
    hi:hasAffiliation inst:Affiliation_PolitecnicoDiMilano ;
    hi:hasAuthorName "Carlo Alberto Bono"^^xsd:string .

inst:Paper_08_Author2 a hi:Author ;
    foaf:name "Barbara Pernici" ;
    hi:hasAffiliation inst:Affiliation_PolitecnicoDiMilano ;
    hi:hasAuthorName "Barbara Pernici"^^xsd:string .

inst:Paper_08_Context a hi:Context ;
    rdfs:label "Emergency Situational Awareness" ;
    hi:hasConstraintConcept hint:TransparencyConstraint ;
    hi:hasContextConcept hint:HealthMonitoringContext ;
    hi:hasInfluenceOn inst:Paper_08_Team ;
    hi:hasPhenomenonConcept hint:DataMismatchPhenomenon,
        hint:TrustShiftPhenomenon .

inst:Paper_08_Exec_ExecuteDataRelevanceAssessment a hi:TaskExecution ;
    rdfs:label "Execute Data Relevance Assessment" ;
    hi:evaluatedBy inst:Paper_08_Evaluation ;
    hi:hasMethodConcept hint:ArgumentationReasoningMethod ;
    hi:realizesTask inst:Paper_08_Task_DataRelevanceAssessment .

inst:Paper_08_Exec_PerformQualityIndicatorEvaluation a hi:TaskExecution ;
    rdfs:label "Perform Quality Indicator Evaluation" ;
    hi:evaluatedBy inst:Paper_08_Evaluation ;
    hi:hasMethodConcept hint:MetaAnalysisScoringMethod ;
    hi:realizesTask inst:Paper_08_Task_QualityIndicatorEvaluation .

inst:Paper_08_Experiment_CrisisScenarioEvaluation a hi:Experiment ;
    rdfs:label "Crisis Scenario Evaluation" ;
    hi:hasAlternativeHypothesis "IQ indicators improve AL performance."^^xsd:string ;
    hi:hasExperimentConcept hint:DeliberationSupportExperiment ;
    hi:hasMetricTested hint:TaskSuccessRateMetric ;
    hi:hasNullHypothesis "IQ indicators do not improve AL performance."^^xsd:string .

inst:Paper_08_Goal_IdentifyRelevantCrisisData a hi:Goal ;
    rdfs:label "Identify Relevant Crisis Data" ;
    hi:hasGoalConcept hint:UserWellbeingGoal ;
    hi:requiresTask inst:Paper_08_Task_DataRelevanceAssessment,
        inst:Paper_08_Task_QualityIndicatorEvaluation,
        inst:Paper_08_Task_SituationalAssessment .

inst:Paper_08_UseCase a hi:ResearchUseCase ;
    rdfs:label "Crisis Data Relevance Identification" ;
    hi:hasDomainConcept hint:HealthAndLifestyleDomain ;
    hi:hasHITeam inst:Paper_08_Team .

inst:Affiliation_PolitecnicoDiMilano a hi:Affiliation ;
    rdfs:label "Politecnico di Milano" ;
    schema1:name "Politecnico di Milano" .

inst:Paper_08_ActiveLearningSystem a hi:ArtificialAgent ;
    rdfs:label "Active Learning System" ;
    hi:hasCapability inst:Paper_08_ActiveLearningSystem_Cap_InformationQualityAnalysis,
        inst:Paper_08_ActiveLearningSystem_Cap_PatternRecognition ;
    hi:hasRoleConcept hint:AIAssistantRole ;
    hi:performsExecution inst:Paper_08_Exec_PerformQualityIndicatorEvaluation .

inst:Paper_08_ActiveLearningSystem_Cap_InformationQualityAnalysis a hi:Capability ;
    rdfs:label "Information Quality Analysis" ;
    hi:allowsTask inst:Paper_08_Task_QualityIndicatorEvaluation ;
    hi:hasCapabilityConcept hint:MetaAnalysisCapability .

inst:Paper_08_CrisisAnalyst a hi:HumanAgent ;
    rdfs:label "Crisis Analyst" ;
    hi:hasCapability inst:Paper_08_CrisisAnalyst_Cap_ContextualUnderstanding,
        inst:Paper_08_CrisisAnalyst_Cap_JudgmentCapability ;
    hi:hasRoleConcept hint:HumanUserRole ;
    hi:performsExecution inst:Paper_08_Exec_ExecuteDataRelevanceAssessment .

inst:Paper_08_CrisisAnalyst_Cap_ContextualUnderstanding a hi:Capability ;
    rdfs:label "Contextual Understanding" ;
    hi:allowsTask inst:Paper_08_Task_SituationalAssessment ;
    hi:hasCapabilityConcept hint:SituationalAwarenessCapability .

inst:Paper_08_CrisisAnalyst_Cap_JudgmentCapability a hi:Capability ;
    rdfs:label "Judgment Capability" ;
    hi:allowsTask inst:Paper_08_Task_DataRelevanceAssessment ;
    hi:hasCapabilityConcept hint:ReasoningCapability .

inst:Paper_08_Evaluation a hi:Evaluation ;
    rdfs:label "Active Learning Evaluation" ;
    hi:hasEvaluationConcept hint:AIInterventionImpactEvaluation ;
    hi:hasExperiment inst:Paper_08_Experiment_CrisisScenarioEvaluation ;
    hi:hasMetricConcept hint:TaskSuccessRateMetric .

inst:Paper_08_Task_SituationalAssessment a hi:Task ;
    rdfs:label "Situational Assessment" ;
    hi:hasTaskConcept hint:SituationalAssessmentTask ;
    hi:requiresCapability inst:Paper_08_CrisisAnalyst_Cap_ContextualUnderstanding .

inst:Paper_08_Team a hi:HITeam ;
    rdfs:label "Crisis Data Relevance Identification Team" ;
    hi:hasGoal inst:Paper_08_Goal_IdentifyRelevantCrisisData ;
    hi:hasMember inst:Paper_08_ActiveLearningSystem,
        inst:Paper_08_CrisisAnalyst ;
    hi:isInfluencedBy inst:Paper_08_Context .

inst:Paper_08_Task_DataRelevanceAssessment a hi:Task ;
    rdfs:label "Data Relevance Assessment" ;
    hi:hasTaskConcept hint:DataCollectionTask ;
    hi:requiresCapability inst:Paper_08_CrisisAnalyst_Cap_JudgmentCapability .

inst:Paper_08_Task_QualityIndicatorEvaluation a hi:Task ;
    rdfs:label "Quality Indicator Evaluation" ;
    hi:hasTaskConcept hint:ExplanationTask ;
    hi:requiresCapability inst:Paper_08_ActiveLearningSystem_Cap_InformationQualityAnalysis .


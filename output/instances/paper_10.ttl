@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix hi: <https://w3id.org/hi-ontology#> .
@prefix hint: <https://w3id.org/hi-thesaurus/> .
@prefix inst: <https://w3id.org/hi-ontology/instances/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

inst:Paper_10 a hi:Paper ;
    hi:describesUseCase inst:Paper_10_UseCase ;
    hi:hasAuthor inst:Paper_10_Author1,
        inst:Paper_10_Author2 ;
    hi:hasKeyword inst:Keyword_ArtificialIntelligence,
        inst:Keyword_Craftsmanship,
        inst:Keyword_Robotics,
        inst:Keyword_SalvageEthnography ;
    hi:hasPublicationYear "2025"^^xsd:gYear ;
    hi:hasTitle "Hybrid Human-AI Systems for Preserving Cultural Heritage and Craftsmanship"^^xsd:string ;
    hi:publishedAt inst:HHAI2025 .

inst:Paper_10_Interaction_Human-aiCollaboration a hi:Interaction ;
    rdfs:label "Human-AI Collaboration" ;
    hi:hasAgentInvolved inst:Paper_10_AiSystem,
        inst:Paper_10_CulturalExpert ;
    hi:hasInteractionIntentConcept hint:GuideIntent ;
    hi:hasInteractionModalityConcept hint:VerbalDialogueModality .

inst:Affiliation_SmartbearSoftware a hi:Affiliation ;
    rdfs:label "SmartBear Software" ;
    schema1:name "SmartBear Software" .

inst:Affiliation_UniversityOfCaliforniaSanDiego a hi:Affiliation ;
    rdfs:label "University of California, San Diego" ;
    schema1:name "University of California, San Diego" .

inst:HHAI2025 a hi:Conference ;
    rdfs:label "HHAI 2025" ;
    hi:hasConferenceName "HHAI 2025"^^xsd:string ;
    hi:hasConferenceYear "2025"^^xsd:gYear .

inst:Keyword_ArtificialIntelligence a skos:Concept ;
    skos:inScheme hint:HIScheme ;
    skos:prefLabel "Artificial Intelligence"@en .

inst:Keyword_Craftsmanship a skos:Concept ;
    skos:inScheme hint:HIScheme ;
    skos:prefLabel "craftsmanship"@en .

inst:Keyword_Robotics a skos:Concept ;
    skos:inScheme hint:HIScheme ;
    skos:prefLabel "robotics"@en .

inst:Keyword_SalvageEthnography a skos:Concept ;
    skos:inScheme hint:HIScheme ;
    skos:prefLabel "salvage ethnography"@en .

inst:Paper_10_AiSystem_Cap_DataGovernance a hi:Capability ;
    rdfs:label "Data Governance" ;
    hi:hasCapabilityConcept hint:SemanticReasoningCapability .

inst:Paper_10_Author1 a hi:Author ;
    foaf:name "Alexandra McDougall" ;
    hi:hasAffiliation inst:Affiliation_SmartbearSoftware ;
    hi:hasAuthorName "Alexandra McDougall"^^xsd:string .

inst:Paper_10_Author2 a hi:Author ;
    foaf:name "Hortense Gerardo" ;
    hi:hasAffiliation inst:Affiliation_UniversityOfCaliforniaSanDiego ;
    hi:hasAuthorName "Hortense Gerardo"^^xsd:string .

inst:Paper_10_Context a hi:Context ;
    rdfs:label "Cultural Preservation Context" ;
    hi:hasConstraintConcept hint:EthicalConstraint,
        hint:PrivacyConstraint ;
    hi:hasContextConcept hint:VirtualExhibitionContext ;
    hi:hasInfluenceOn inst:Paper_10_Team ;
    hi:hasPhenomenonConcept hint:KnowledgeMismatchPhenomenon,
        hint:TrustShiftPhenomenon .

inst:Paper_10_CulturalExpert_Cap_CulturalJudgment a hi:Capability ;
    rdfs:label "Cultural Judgment" ;
    hi:hasCapabilityConcept hint:ClinicalJudgmentCapability .

inst:Paper_10_Exec_ExecuteDataCollection a hi:TaskExecution ;
    rdfs:label "Execute Data Collection" ;
    hi:evaluatedBy inst:Paper_10_Evaluation ;
    hi:hasMethodConcept hint:DataCollectionMethod ;
    hi:realizesTask inst:Paper_10_Task_DataCollectionTask .

inst:Paper_10_Exec_ExecuteDataProcessing a hi:TaskExecution ;
    rdfs:label "Execute Data Processing" ;
    hi:evaluatedBy inst:Paper_10_Evaluation ;
    hi:hasMethodConcept hint:SemanticEmbeddingMethod ;
    hi:realizesTask inst:Paper_10_Task_DataProcessing .

inst:Paper_10_Exec_ExecuteDepthPerceptionEnhancement a hi:TaskExecution ;
    rdfs:label "Execute Depth Perception Enhancement" ;
    hi:evaluatedBy inst:Paper_10_Evaluation ;
    hi:hasMethodConcept hint:ReinforcementLearningMethod ;
    hi:realizesTask inst:Paper_10_Task_DepthPerceptionEnhancement .

inst:Paper_10_Exec_ExecuteEthicalDataGovernance a hi:TaskExecution ;
    rdfs:label "Execute Ethical Data Governance" ;
    hi:evaluatedBy inst:Paper_10_Evaluation ;
    hi:hasMethodConcept hint:ProtocolNegotiationMethod ;
    hi:realizesTask inst:Paper_10_Task_EthicalDataGovernance .

inst:Paper_10_Experiment_CulturalDataGovernanceExperiment a hi:Experiment ;
    rdfs:label "Cultural Data Governance Experiment" ;
    hi:hasAlternativeHypothesis "Data governance enhances trust."^^xsd:string ;
    hi:hasExperimentConcept hint:DeliberationSupportExperiment ;
    hi:hasMetricTested hint:TrustPreservationMetric ;
    hi:hasNullHypothesis "Data governance does not affect trust."^^xsd:string .

inst:Paper_10_Goal_PreserveCulturalPractices a hi:Goal ;
    rdfs:label "Preserve Cultural Practices" ;
    hi:hasGoalConcept hint:EnhancedVisitorGoal ;
    hi:requiresTask inst:Paper_10_Task_DataCollectionTask,
        inst:Paper_10_Task_DataProcessing,
        inst:Paper_10_Task_DepthPerceptionEnhancement,
        inst:Paper_10_Task_EthicalDataGovernance .

inst:Paper_10_UseCase a hi:ResearchUseCase ;
    rdfs:label "Cultural Heritage Preservation" ;
    hi:hasDomainConcept hint:DigitalMuseumDomain ;
    hi:hasHITeam inst:Paper_10_Team .

inst:Paper_10_AiSystem a hi:ArtificialAgent ;
    rdfs:label "AI System" ;
    hi:hasCapability inst:Paper_10_AiSystem_Cap_DataGovernance,
        inst:Paper_10_AiSystem_Cap_DepthPerception,
        inst:Paper_10_AiSystem_Cap_PatternRecognition ;
    hi:hasRoleConcept hint:AIAssistantRole ;
    hi:performsExecution inst:Paper_10_Exec_ExecuteDataProcessing,
        inst:Paper_10_Exec_ExecuteDepthPerceptionEnhancement .

inst:Paper_10_AiSystem_Cap_PatternRecognition a hi:Capability ;
    rdfs:label "Pattern Recognition" ;
    hi:allowsTask inst:Paper_10_Task_DataProcessing ;
    hi:hasCapabilityConcept hint:PatternLearningCapability .

inst:Paper_10_CulturalExpert a hi:HumanAgent ;
    rdfs:label "Cultural Expert" ;
    hi:hasCapability inst:Paper_10_CulturalExpert_Cap_CulturalJudgment,
        inst:Paper_10_CulturalExpert_Cap_EthicalOversight ;
    hi:hasRoleConcept hint:HumanUserRole ;
    hi:performsExecution inst:Paper_10_Exec_ExecuteDataCollection,
        inst:Paper_10_Exec_ExecuteEthicalDataGovernance .

inst:Paper_10_CulturalExpert_Cap_EthicalOversight a hi:Capability ;
    rdfs:label "Ethical Oversight" ;
    hi:allowsTask inst:Paper_10_Task_EthicalDataGovernance ;
    hi:hasCapabilityConcept hint:ReasoningCapability .

inst:Paper_10_Team a hi:HITeam ;
    rdfs:label "Cultural Heritage Preservation Team" ;
    hi:hasGoal inst:Paper_10_Goal_PreserveCulturalPractices ;
    hi:hasMember inst:Paper_10_AiSystem,
        inst:Paper_10_CulturalExpert ;
    hi:isInfluencedBy inst:Paper_10_Context .

inst:Paper_10_AiSystem_Cap_DepthPerception a hi:Capability ;
    rdfs:label "Depth Perception" ;
    hi:allowsTask inst:Paper_10_Task_DataCollectionTask,
        inst:Paper_10_Task_DepthPerceptionEnhancement ;
    hi:hasCapabilityConcept hint:SensingCapability .

inst:Paper_10_Task_DataCollectionTask a hi:Task ;
    rdfs:label "Data Collection Task" ;
    hi:hasTaskConcept hint:DataCollectionTask ;
    hi:requiresCapability inst:Paper_10_AiSystem_Cap_DepthPerception .

inst:Paper_10_Task_DataProcessing a hi:Task ;
    rdfs:label "Data Processing" ;
    hi:hasTaskConcept hint:SemanticReasoningTask ;
    hi:requiresCapability inst:Paper_10_AiSystem_Cap_PatternRecognition .

inst:Paper_10_Task_DepthPerceptionEnhancement a hi:Task ;
    rdfs:label "Depth Perception Enhancement" ;
    hi:hasTaskConcept hint:ReconstructTrajectoryTask ;
    hi:requiresCapability inst:Paper_10_AiSystem_Cap_DepthPerception .

inst:Paper_10_Task_EthicalDataGovernance a hi:Task ;
    rdfs:label "Ethical Data Governance" ;
    hi:hasTaskConcept hint:ConflictResolutionTask ;
    hi:requiresCapability inst:Paper_10_CulturalExpert_Cap_EthicalOversight .

inst:Paper_10_Evaluation a hi:Evaluation ;
    rdfs:label "Cultural Preservation Evaluation" ;
    hi:hasEvaluationConcept hint:TransparencyEvaluation ;
    hi:hasExperiment inst:Paper_10_Experiment_CulturalDataGovernanceExperiment ;
    hi:hasMetricConcept hint:FairOutcomeMetric,
        hint:TrustPreservationMetric .


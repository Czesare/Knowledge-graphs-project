@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix hi: <https://w3id.org/hi-ontology#> .
@prefix hint: <https://w3id.org/hi-thesaurus/> .
@prefix inst: <https://w3id.org/hi-ontology/instances/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

inst:Paper_10 a hi:Paper ;
    hi:describesUseCase inst:Paper_10_UseCase ;
    hi:hasAuthor inst:Paper_10_Author1,
        inst:Paper_10_Author2 ;
    hi:hasKeyword "Artificial Intelligence",
        "craftsmanship",
        "salvage ethnography",
        "robotics" ;
    hi:hasPublicationYear "2025"^^xsd:gYear ;
    hi:hasTitle "Hybrid Human-AI Systems for Preserving Cultural Heritage and Craftsmanship"^^xsd:string ;
    hi:publishedAt inst:HHAI2025 .

inst:Paper_10_UseCase a hi:ResearchUseCase ;
    rdfs:label "Cultural Heritage & Craftsmanship Preservation" ;
    hi:hasDomainConcept hint:DigitalMuseumDomain ;
    hi:hasHITeam inst:Paper_10_Team .

inst:Paper_10_Context a hi:Context ;
    rdfs:label "Archival footage training context" ;
    hi:hasContextConcept hint:VirtualExhibitionContext ;
    hi:hasConstraintConcept hint:EthicalConstraint,
        hint:PrivacyConstraint,
        hint:AutonomyConstraint ;
    hi:hasPhenomenonConcept hint:SkillsComplementarityPhenomenon,
        hint:TrustShiftPhenomenon,
        hint:RiskExposurePhenomenon ;
    hi:hasInfluenceOn inst:Paper_10_Team .

inst:Paper_10_Team a hi:HITeam ;
    rdfs:label "Cultural Heritage Preservation Team" ;
    hi:hasGoal inst:Paper_10_Goal_EthicalHeritagePreservation ;
    hi:hasMember inst:Paper_10_ArchivalFootageAISystem,
        inst:Paper_10_CulturalHeritageSteward ;
    hi:isInfluencedBy inst:Paper_10_Context .

inst:Paper_10_Goal_EthicalHeritagePreservation a hi:Goal ;
    rdfs:label "Ethical Preservation of Cultural Heritage" ;
    hi:hasGoalConcept hint:EnhancedVisitorGoal ;
    hi:requiresTask inst:Paper_10_Task_ArchivalFootageCollection,
        inst:Paper_10_Task_VideoSegmentationAndTagging,
        inst:Paper_10_Task_DataGovernanceNegotiation,
        inst:Paper_10_Task_SkillLearningFromVideo .

# -------------------------
# Authors + affiliations
# -------------------------
inst:Paper_10_Author1 a hi:Author ;
    foaf:name "Alexandra McDougall" ;
    hi:hasAffiliation inst:Affiliation_SmartBearSoftware ;
    hi:hasAuthorName "Alexandra McDougall"^^xsd:string .

inst:Paper_10_Author2 a hi:Author ;
    foaf:name "Hortense Gerardo" ;
    hi:hasAffiliation inst:Affiliation_UCSD ;
    hi:hasAuthorName "Hortense Gerardo"^^xsd:string .

inst:Affiliation_SmartBearSoftware a hi:Affiliation ;
    rdfs:label "SmartBear Software" ;
    schema1:name "SmartBear Software" .

inst:Affiliation_UCSD a hi:Affiliation ;
    rdfs:label "University of California, San Diego" ;
    schema1:name "University of California, San Diego" .

# -------------------------
# Agents
# -------------------------
inst:Paper_10_CulturalHeritageSteward a hi:HumanAgent ;
    rdfs:label "Cultural Heritage Steward" ;
    hi:hasRoleConcept hint:BuilderRole ;
    hi:hasCapability inst:Paper_10_HumanCap_CulturalStewardship,
        inst:Paper_10_HumanCap_EthicalOversight,
        inst:Paper_10_HumanCap_Negotiation ;
    hi:performsExecution inst:Paper_10_Exec_CollectFootage,
        inst:Paper_10_Exec_NegotiateGovernance .

inst:Paper_10_ArchivalFootageAISystem a hi:ArtificialAgent ;
    rdfs:label "Archival Footage AI System" ;
    hi:hasRoleConcept hint:AIAssistantRole ;
    hi:hasCapability inst:Paper_10_AICap_MultimodalUnderstanding,
        inst:Paper_10_AICap_PerceptionSensing,
        inst:Paper_10_AICap_PatternLearning,
        inst:Paper_10_AICap_ReinforcementLearning ;
    hi:performsExecution inst:Paper_10_Exec_ProcessVideo,
        inst:Paper_10_Exec_LearnSkills .

# -------------------------
# Capabilities
# -------------------------
inst:Paper_10_HumanCap_CulturalStewardship a hi:Capability ;
    rdfs:label "Cultural Stewardship" ;
    hi:hasCapabilityConcept hint:DomainSpecificCapability ;
    hi:allowsTask inst:Paper_10_Task_ArchivalFootageCollection,
        inst:Paper_10_Task_DataGovernanceNegotiation .

inst:Paper_10_HumanCap_EthicalOversight a hi:Capability ;
    rdfs:label "Ethical Oversight" ;
    hi:hasCapabilityConcept hint:ReasoningCapability .

inst:Paper_10_HumanCap_Negotiation a hi:Capability ;
    rdfs:label "Negotiation" ;
    hi:hasCapabilityConcept hint:NegotiationCapability .

inst:Paper_10_AICap_MultimodalUnderstanding a hi:Capability ;
    rdfs:label "Multimodal Understanding (Video)" ;
    hi:hasCapabilityConcept hint:MultimodalInterpretationCapability .

inst:Paper_10_AICap_PerceptionSensing a hi:Capability ;
    rdfs:label "Perception / Sensing" ;
    hi:hasCapabilityConcept hint:PerceptionSensingCapability .

inst:Paper_10_AICap_PatternLearning a hi:Capability ;
    rdfs:label "Pattern Learning" ;
    hi:hasCapabilityConcept hint:PatternLearningCapability .

inst:Paper_10_AICap_ReinforcementLearning a hi:Capability ;
    rdfs:label "Reinforcement Learning" ;
    hi:hasCapabilityConcept hint:ReinforcementLearningCapability .

# -------------------------
# Tasks
# -------------------------
inst:Paper_10_Task_ArchivalFootageCollection a hi:Task ;
    rdfs:label "Archival Footage Collection" ;
    hi:hasTaskConcept hint:DataCollectionTask ;
    hi:requiresCapability inst:Paper_10_HumanCap_CulturalStewardship .

inst:Paper_10_Task_VideoSegmentationAndTagging a hi:Task ;
    rdfs:label "Video Segmentation & Metadata Tagging" ;
    hi:hasTaskConcept hint:MultimodalInputInterpretationTask ;
    hi:requiresCapability inst:Paper_10_AICap_MultimodalUnderstanding .

inst:Paper_10_Task_DataGovernanceNegotiation a hi:Task ;
    rdfs:label "Ethical Data Governance & Consent" ;
    hi:hasTaskConcept hint:AllocationNegotationTask ;
    hi:requiresCapability inst:Paper_10_HumanCap_Negotiation .

inst:Paper_10_Task_SkillLearningFromVideo a hi:Task ;
    rdfs:label "Skill Learning from Archival Video" ;
    hi:hasTaskConcept hint:PolicyLearningTask ;
    hi:requiresCapability inst:Paper_10_AICap_ReinforcementLearning .

# -------------------------
# Task executions (linked to methods that already exist in the thesaurus)
# -------------------------
inst:Paper_10_Exec_CollectFootage a hi:TaskExecution ;
    rdfs:label "Collect Footage" ;
    hi:hasMethodConcept hint:KnowledgeGraphQueryMethod ;
    hi:realizesTask inst:Paper_10_Task_ArchivalFootageCollection .

inst:Paper_10_Exec_ProcessVideo a hi:TaskExecution ;
    rdfs:label "Process Video (Segment/Tag/Depth)" ;
    hi:hasMethodConcept hint:SemanticEmbeddingMethod ;
    hi:realizesTask inst:Paper_10_Task_VideoSegmentationAndTagging .

inst:Paper_10_Exec_NegotiateGovernance a hi:TaskExecution ;
    rdfs:label "Negotiate Governance Rules" ;
    hi:hasMethodConcept hint:ArgumentationReasoningMethod ;
    hi:realizesTask inst:Paper_10_Task_DataGovernanceNegotiation .

inst:Paper_10_Exec_LearnSkills a hi:TaskExecution ;
    rdfs:label "Learn Skills from Demonstrations" ;
    hi:hasMethodConcept hint:ReinforcementLearningMethod ;
    hi:realizesTask inst:Paper_10_Task_SkillLearningFromVideo .

# -------------------------
# Interaction
# -------------------------
inst:Paper_10_Interaction_GovernanceNegotiation a hi:Interaction ;
    rdfs:label "Consent & Governance Negotiation" ;
    hi:hasAgentInvolved inst:Paper_10_ArchivalFootageAISystem,
        inst:Paper_10_CulturalHeritageSteward ;
    hi:hasInteractionIntentConcept hint:NegotiationIntent ;
    hi:hasInteractionModalityConcept hint:DashboardModality .

# -------------------------
# Evaluation (proposal-level; keep lightweight)
# -------------------------
inst:Paper_10_Evaluation a hi:Evaluation ;
    rdfs:label "Ethical Data Governance Evaluation" ;
    hi:hasEvaluationConcept hint:TransparencyEvaluation,
        hint:NegotationImpactEvaluation ;
    hi:hasMetricConcept hint:TrustPreservationMetric,
        hint:InformationQualityMetric .
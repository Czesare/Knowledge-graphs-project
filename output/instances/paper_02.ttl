@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix hi: <https://w3id.org/hi-ontology#> .
@prefix hint: <https://w3id.org/hi-thesaurus/> .
@prefix inst: <https://w3id.org/hi-ontology/instances/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

inst:Paper_02 a hi:Paper ;
    hi:describesUseCase inst:Paper_02_UseCase ;
    hi:hasAuthor inst:Paper_02_Author1,
        inst:Paper_02_Author2,
        inst:Paper_02_Author3,
        inst:Paper_02_Author4 ;
    hi:hasKeyword inst:Keyword_ConversationalAi,
        inst:Keyword_InformationExtraction,
        inst:Keyword_SocialConversations ;
    hi:hasPublicationYear "2025"^^xsd:gYear ;
    hi:hasTitle "Extracting Triples from Dialogues for Conversational Social Agents"^^xsd:string ;
    hi:publishedAt inst:HHAI2025 .

inst:Paper_02_Interaction_Human-aiDialogue a hi:Interaction ;
    rdfs:label "Human-AI Dialogue" ;
    hi:hasAgentInvolved inst:Paper_02_DialogueAnnotator,
        inst:Paper_02_TripleExtractionModel ;
    hi:hasInteractionIntentConcept hint:ExplanationIntent ;
    hi:hasInteractionModalityConcept hint:TextChatModality .

inst:Affiliation_InovacioniCentarEtfBelgradeRs a hi:Affiliation ;
    rdfs:label "Inovacioni Centar ETF: Belgrade, RS" ;
    schema1:name "Inovacioni Centar ETF: Belgrade, RS" .

inst:HHAI2025 a hi:Conference ;
    rdfs:label "HHAI 2025" ;
    hi:hasConferenceName "HHAI 2025"^^xsd:string ;
    hi:hasConferenceYear "2025"^^xsd:gYear .

inst:Keyword_ConversationalAi a skos:Concept ;
    skos:inScheme hint:HIScheme ;
    skos:prefLabel "Conversational AI"@en .

inst:Keyword_InformationExtraction a skos:Concept ;
    skos:inScheme hint:HIScheme ;
    skos:prefLabel "Information extraction"@en .

inst:Keyword_SocialConversations a skos:Concept ;
    skos:inScheme hint:HIScheme ;
    skos:prefLabel "Social Conversations"@en .

inst:Paper_02_Author1 a hi:Author ;
    foaf:name "Piek Vossen" ;
    hi:hasAffiliation inst:Affiliation_VrijeUniversiteitAmsterdam ;
    hi:hasAuthorName "Piek Vossen"^^xsd:string .

inst:Paper_02_Author2 a hi:Author ;
    foaf:name "Selene Báez Santamaría" ;
    hi:hasAffiliation inst:Affiliation_VrijeUniversiteitAmsterdam ;
    hi:hasAuthorName "Selene Báez Santamaría"^^xsd:string .

inst:Paper_02_Author3 a hi:Author ;
    foaf:name "Lenka Bajcetic" ;
    hi:hasAffiliation inst:Affiliation_InovacioniCentarEtfBelgradeRs ;
    hi:hasAuthorName "Lenka Bajcetic"^^xsd:string .

inst:Paper_02_Author4 a hi:Author ;
    foaf:name "Thomas Belluci" ;
    hi:hasAffiliation inst:Affiliation_VrijeUniversiteitAmsterdam ;
    hi:hasAuthorName "Thomas Belluci"^^xsd:string .

inst:Paper_02_Context a hi:Context ;
    rdfs:label "Social Conversation Context" ;
    hi:hasConstraintConcept hint:TransparencyConstraint ;
    hi:hasContextConcept hint:OnlineLearningContext ;
    hi:hasInfluenceOn inst:Paper_02_Team ;
    hi:hasPhenomenonConcept hint:KnowledgeMismatchPhenomenon,
        hint:TrustShiftPhenomenon .

inst:Paper_02_Evaluation a hi:Evaluation ;
    rdfs:label "Model Performance Evaluation" ;
    hi:hasEvaluationConcept hint:TransparencyEvaluation ;
    hi:hasExperiment inst:Paper_02_Experiment_TripleExtractionAccuracyTest ;
    hi:hasMetricConcept hint:ExplanationClarityMetric .

inst:Paper_02_Exec_ExecuteTripleExtraction a hi:TaskExecution ;
    rdfs:label "Execute Triple Extraction" ;
    hi:evaluatedBy inst:Paper_02_Evaluation ;
    hi:hasMethodConcept hint:SemanticLinkingMethod ;
    hi:realizesTask inst:Paper_02_Task_TripleExtraction .

inst:Paper_02_Experiment_TripleExtractionAccuracyTest a hi:Experiment ;
    rdfs:label "Triple Extraction Accuracy Test" ;
    hi:hasAlternativeHypothesis "The model improves triple extraction accuracy."^^xsd:string ;
    hi:hasExperimentConcept hint:DeliberationSupportExperiment ;
    hi:hasMetricTested hint:ExplanationClarityMetric ;
    hi:hasNullHypothesis "The model does not improve triple extraction accuracy."^^xsd:string .

inst:Paper_02_Goal_ExtractKnowledgeFromDialogues a hi:Goal ;
    rdfs:label "Extract Knowledge from Dialogues" ;
    hi:hasGoalConcept hint:EnhancedVisitorGoal ;
    hi:requiresTask inst:Paper_02_Task_DialogueAnnotation,
        inst:Paper_02_Task_ModelEvaluation,
        inst:Paper_02_Task_TripleExtraction .

inst:Paper_02_TripleExtractionModel_Cap_LanguageProcessing a hi:Capability ;
    rdfs:label "Language Processing" ;
    hi:hasCapabilityConcept hint:MultimodalInterpretationCapability .

inst:Paper_02_TripleExtractionModel_Cap_PatternRecognition a hi:Capability ;
    rdfs:label "Pattern Recognition" ;
    hi:hasCapabilityConcept hint:PatternLearningCapability .

inst:Paper_02_UseCase a hi:ResearchUseCase ;
    rdfs:label "Triple Extraction from Social Dialogues" ;
    hi:hasDomainConcept hint:DigitalMuseumDomain ;
    hi:hasHITeam inst:Paper_02_Team .

inst:Paper_02_DialogueAnnotator a hi:HumanAgent ;
    rdfs:label "Dialogue Annotator" ;
    hi:hasCapability inst:Paper_02_DialogueAnnotator_Cap_ContextualUnderstanding,
        inst:Paper_02_DialogueAnnotator_Cap_JudgmentCapability ;
    hi:hasRoleConcept hint:HumanUserRole .

inst:Paper_02_DialogueAnnotator_Cap_ContextualUnderstanding a hi:Capability ;
    rdfs:label "Contextual Understanding" ;
    hi:allowsTask inst:Paper_02_Task_DialogueAnnotation ;
    hi:hasCapabilityConcept hint:SituationalAwarenessCapability .

inst:Paper_02_DialogueAnnotator_Cap_JudgmentCapability a hi:Capability ;
    rdfs:label "Judgment Capability" ;
    hi:allowsTask inst:Paper_02_Task_ModelEvaluation ;
    hi:hasCapabilityConcept hint:ClinicalJudgmentCapability .

inst:Paper_02_Task_DialogueAnnotation a hi:Task ;
    rdfs:label "Dialogue Annotation" ;
    hi:hasTaskConcept hint:DataCollectionTask ;
    hi:requiresCapability inst:Paper_02_DialogueAnnotator_Cap_ContextualUnderstanding .

inst:Paper_02_Task_ModelEvaluation a hi:Task ;
    rdfs:label "Model Evaluation" ;
    hi:hasTaskConcept hint:ExplanationTask ;
    hi:requiresCapability inst:Paper_02_DialogueAnnotator_Cap_JudgmentCapability .

inst:Paper_02_Team a hi:HITeam ;
    rdfs:label "Triple Extraction from Social Dialogues Team" ;
    hi:hasGoal inst:Paper_02_Goal_ExtractKnowledgeFromDialogues ;
    hi:hasMember inst:Paper_02_DialogueAnnotator,
        inst:Paper_02_TripleExtractionModel ;
    hi:isInfluencedBy inst:Paper_02_Context .

inst:Paper_02_TripleExtractionModel a hi:ArtificialAgent ;
    rdfs:label "Triple Extraction Model" ;
    hi:hasCapability inst:Paper_02_TripleExtractionModel_Cap_LanguageProcessing,
        inst:Paper_02_TripleExtractionModel_Cap_PatternRecognition,
        inst:Paper_02_TripleExtractionModel_Cap_SemanticReasoning ;
    hi:hasRoleConcept hint:AIAssistantRole ;
    hi:performsExecution inst:Paper_02_Exec_ExecuteTripleExtraction .

inst:Paper_02_TripleExtractionModel_Cap_SemanticReasoning a hi:Capability ;
    rdfs:label "Semantic Reasoning" ;
    hi:allowsTask inst:Paper_02_Task_TripleExtraction ;
    hi:hasCapabilityConcept hint:SemanticReasoningCapability .

inst:Affiliation_VrijeUniversiteitAmsterdam a hi:Affiliation ;
    rdfs:label "Vrije Universiteit Amsterdam" ;
    schema1:name "Vrije Universiteit Amsterdam" .

inst:Paper_02_Task_TripleExtraction a hi:Task ;
    rdfs:label "Triple Extraction" ;
    hi:hasTaskConcept hint:KnowledgeGraphQueryTask ;
    hi:requiresCapability inst:Paper_02_TripleExtractionModel_Cap_SemanticReasoning .


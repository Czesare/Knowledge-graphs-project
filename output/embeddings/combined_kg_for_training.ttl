    rdfs:comment "A human individual described using the FOAF vocabulary. Represents natural persons who may participate in, interact with, or be modeled within a Hybrid Intelligence scenario."@en .

hint:AIAssistantRole a skos:Concept ;
    skos:broader hint:Role ;
    skos:definition "A role where the agent assists the system in performing tasks and achieving goals."@en ;
    skos:inScheme hint:HIScheme ;
    skos:prefLabel "System Assistant Role"@en .

hint:EthicalConstraint a skos:Concept ;
    rdfs:seeAlso dbr:Ethics ;
    skos:broader hint:Constraint ;
    skos:closeMatch wd:Q9465 ;
    skos:definition "A constraint that ensures the ethical operation of a Hybrid Intelligence system."@en ;
    skos:exactMatch hi:EthicalConstraint ;
    skos:inScheme hint:HIScheme ;
    skos:prefLabel "Ethical Constraint"@en .

hint:PatternLearningCapability a skos:Concept ;
    rdfs:seeAlso dbr:Machine_learning ;
    skos:broader hint:CommunicationExplanationCapability ;
    skos:closeMatch wd:Q2539 ;
    skos:definition "Capability to learn and recognize patterns in data."@en ;
    skos:inScheme hint:Scheme ;
    skos:prefLabel "Pattern learning capability"@en .

hint:TaskSuccessRateMetric a skos:Concept ;
    skos:broader hint:Metric ;
    skos:definition "A metric that measures the success rate of task completion by Hybrid Intelligence systems."@en ;
    skos:inScheme hint:HIScheme ;
    skos:prefLabel "Task Success Rate Metric"@en ;
    skos:relatedMatch wd:Q3992824 .

hi:Adaptiveness a hi:Capability ;
    rdfs:label "Adaptiveness"@en .

hi:Model a owl:Class ;
    rdfs:label "Model"@en ;
    rdfs:comment "A computational model (e.g., a language model) used by an agent during task execution."@en .

hint:Evaluation a skos:Concept ;
    skos:definition "The process of assessing the performance, effectiveness, or impact of Hybrid Intelligence systems."@en ;
    skos:exactMatch hi:Evaluation ;
    skos:inScheme hint:HIScheme ;
    skos:prefLabel "Evaluation"@en ;
    skos:relatedMatch wd:Q1379672 .

hint:Metric a skos:Concept ;
    skos:definition "A quantitative measure used to evaluate specific aspects of Hybrid Intelligence systems."@en ;
    skos:exactMatch hi:Metric ;
    skos:inScheme hint:HIScheme ;
    skos:prefLabel "Metric"@en .

hi:Domain a owl:Class ;
    rdfs:label "Domain"@en ;
    rdfs:comment "A domain of application or knowledge relevant to a use case."@en .

hi:Transparency a hi:Capability ;
    rdfs:label "Transparency"@en .

hi:Paper a owl:Class ;
    rdfs:label "Paper"@en ;
    rdfs:comment "A research publication (e.g. conference paper) that describes one or more Hybrid Intelligence use cases. Every paper must have at least one author and describe at least one use case."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass hi:Author ;
            owl:onProperty hi:hasAuthor ],
        [ a owl:Restriction ;
            owl:onProperty hi:describesUseCase ;
            owl:someValuesFrom hi:UseCase ],
        bibo:AcademicArticle ;
    owl:disjointWith hi:Agent,
        hi:HITeam,
        hi:Task .

hi:Affiliation a owl:Class ;
    rdfs:label "Affiliation"@en ;
    rdfs:comment "An institution or organization that an author is affiliated with."@en ;
    rdfs:subClassOf schema1:Organization .

hi:Method a owl:Class ;
    rdfs:label "Method"@en ;
    rdfs:comment "A method or approach used in task execution or modeling."@en .

hi:Agent a owl:Class ;
    rdfs:label "Agent"@en ;
    rdfs:comment "An autonomous entity capable of having roles, goals, and capabilities within a hybrid intelligence system."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty hi:hasCapability ;
            owl:someValuesFrom hi:Capability ] .

hint:TaskExecution a skos:Concept ;
    skos:definition "The process of carrying out a specific task within a Hybrid Intelligence system."@en ;
    skos:exactMatch hi:TaskExecution ;
    skos:inScheme hint:HIScheme ;
    skos:prefLabel "Task Execution"@en .

hi:Communication a hi:Capability ;
    rdfs:label "Communication"@en .

hi:Evaluation a owl:Class ;
    rdfs:label "Evaluation"@en ;
    rdfs:comment "A process of assessing the quality or outcome of executions, methods, or goals."@en ;
    owl:disjointWith hi:Task .

hi:UseCase a owl:Class ;
    rdfs:label "Use Case"@en ;
    rdfs:comment "A structured situation describing a specific hybrid intelligence scenario (previously 'Scenario')."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty hi:hasHITeam ;
            owl:someValuesFrom hi:HITeam ] ;
    owl:disjointWith hi:Agent,
        hi:Capability,
        hi:Task .

hint:Task a skos:Concept ;
    skos:definition "A specific activity or operation that a Hybrid Intelligence system performs to achieve its goals."@en ;
    skos:exactMatch hi:Task ;
    skos:inScheme hint:HIScheme ;
    skos:prefLabel "Task"@en ;
    skos:relatedMatch wd:Q759676 .

hi:Author a owl:Class ;
    rdfs:label "Author"@en ;
    rdfs:comment "A person who authored a research paper about Hybrid Intelligence."@en ;
    rdfs:subClassOf foaf:Person .

hi:Experiment a owl:Class ;
    rdfs:label "Experiment"@en ;
    rdfs:comment "An empirical setup linked to an evaluation that tests metrics and hypotheses."@en ;
    owl:disjointWith hi:Evaluation .

hi:Goal a owl:Class ;
    rdfs:label "Goal"@en ;
    rdfs:comment "A desired outcome pursued by an HI team, requiring one or more tasks to be completed."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass hi:Task ;
            owl:onProperty hi:requiresTask ],
        [ a owl:Restriction ;
            owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass hi:Task ;
            owl:onProperty hi:requiresTask ] ;
    owl:disjointWith hi:Agent,
        hi:Task .

hi:HumanAgent a owl:Class ;
    rdfs:label "Human Agent"@en ;
    rdfs:comment "A human participant in the hybrid intelligence system, possessing cognitive and perceptual abilities."@en ;
    rdfs:subClassOf foaf:Person,
        hi:Agent ;
    owl:disjointWith hi:ArtificialAgent .

hi:ArtificialAgent a owl:Class ;
    rdfs:label "Artificial Agent"@en ;
    rdfs:comment "An artificial or computational agent (robot, software, etc.) collaborating with human agents."@en ;
    rdfs:subClassOf hi:Agent .

hi:Context a owl:Class ;
    rdfs:label "Context"@en ;
    rdfs:comment "Situational conditions (environmental, cultural, cognitive) under which tasks and evaluations occur."@en ;
    owl:disjointWith hi:Agent .

hi:HITeam a owl:Class ;
    rdfs:label "HI Team"@en ;
    rdfs:comment "A hybrid intelligence team composed of human and artificial agents pursuing a shared goal."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass hi:ArtificialAgent ;
            owl:onProperty hi:hasMember ],
        [ a owl:Restriction ;
            owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass hi:HumanAgent ;
            owl:onProperty hi:hasMember ],
        [ a owl:Restriction ;
            owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass hi:ArtificialAgent ;
            owl:onProperty hi:hasMember ],
        [ a owl:Restriction ;
            owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass hi:HumanAgent ;
            owl:onProperty hi:hasMember ],
        [ a owl:Restriction ;
            owl:onProperty hi:hasGoal ;
            owl:someValuesFrom hi:Goal ] .

hi:Interaction a owl:Class ;
    rdfs:label "Interaction"@en ;
    rdfs:comment "A multi-agent task execution where two or more agents coordinate (verbal, symbolic, or physical) toward a goal."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minQualifiedCardinality "2"^^xsd:nonNegativeInteger ;
            owl:onClass hi:Agent ;
            owl:onProperty hi:hasAgentInvolved ],
        [ a owl:Restriction ;
            owl:minQualifiedCardinality "2"^^xsd:nonNegativeInteger ;
            owl:onClass hi:Agent ;
            owl:onProperty hi:hasAgentInvolved ] .

hi:Data a owl:Class ;
    rdfs:label "Data"@en ;
    rdfs:comment "Data used as input or output in models and task executions."@en .

hi:TaskExecution a owl:Class ;
    rdfs:label "Task Execution"@en ;
    rdfs:comment "The realization or performance of a specific task by an agent using a method."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onClass hi:Task ;
            owl:onProperty hi:realizesTask ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ] .

hi:Task a owl:Class ;
    rdfs:label "Task"@en ;
    rdfs:comment "A unit of purposeful activity executed by an agent toward achieving a goal."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass hi:Capability ;
            owl:onProperty hi:requiresCapability ],
        [ a owl:Restriction ;
            owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass hi:Capability ;
            owl:onProperty hi:requiresCapability ] .

hi:Capability a owl:Class ;
    rdfs:label "Capability"@en ;
    rdfs:comment "A skill, competence, or functional capacity that allows an agent to perform or enable a task."@en .

hint:HIScheme a skos:ConceptScheme ;
    dc:creator "to be added" ;
    dc:description "A controlled thesaurus of terms to describe Hybrid Intelligence (HI)."@en ;
    dc:license <https://creativecommons.org/licenses/by/4.0/> ;
    dc:title "Hybrid INtelligence Thesaurus (HINT)"@en ;
    dcterms:created "2025-11-15"^^xsd:date ;
    vann:preferredNamespacePrefix "hint" ;
    vann:preferredNamespaceUri "https://w3id.org/hi-thesaurus#" ;
    skos:prefLabel "Hybrid INtelligence Thesaurus"@en .

skos:Concept a owl:Class ;
    rdfs:label "Concept"@en ;
    rdfs:comment "A SKOS concept representing a unit of thought, used for controlled vocabularies and thesauri."@en .

[] a schema1:Organization ;
    schema1:name "Knowledge in AI (KAI) Group - Vrije Universiteit Amsterdam" .

[] a schema1:Organization ;
    schema1:name "Knowledge in AI (KAI) Group - Vrije Universiteit Amsterdam" .

[] a schema1:Organization ;
    schema1:name "Knowledge in AI (KAI) Group - Vrije Universiteit Amsterdam" .


bibo:AcademicArticle a owl:Class ;
    rdfs:label "Academic Article"@en ;
    rdfs:comment "An academic article from the BIBO ontology."@en .

schema1:Event a owl:Class ;
    rdfs:label "Event"@en ;
    rdfs:comment "An event from Schema.org vocabulary."@en .

hi:AgentBasedSocialSimulationMethod a hi:Method ;
    rdfs:label "Agent-based social simulation"@en .

hi:AlexLearningSupportTeam a hi:HITeam ;
    hi:hasGoal hi:SupportPersonalizedLearningGoal ;
    hi:hasMember hi:Alex,
        hi:AssistiveRobot,
        hi:TeacherUser,
        hi:Therapist ;
    hi:isInfluencedBy hi:PersonalizedLearningContext .

hi:AlphaFoldPredictionModel a hi:Model ;
    rdfs:label "AlphaFold prediction model"@en ;
    hi:hasInputData hi:ProteinSequenceDataset ;
    hi:hasMethod hi:ProteinStructurePredictionMethod ;
    hi:hasOutputData hi:PredictedProteinStructureData .

hi:ArchivalCurationTeam a hi:HITeam ;
    rdfs:label "Archival curation team"@en ;
    hi:hasGoal hi:PreserveAndCurateArchivalKnowledgeGoal ;
    hi:hasMember hi:ArchivalFootageAISystem,
        hi:CulturalHeritageSteward ;
    hi:isInfluencedBy hi:ArchivalCurationContext .

hi:ArchivalSegmentationModel a hi:Model ;
    rdfs:label "Archival segmentation model"@en ;
    hi:hasInputData hi:ArchivalFootageDataset ;
    hi:hasMethod hi:MultimodalSegmentationMethod ;
    hi:hasOutputData hi:TaggedArchivalSegments .

hi:ArchiveVideoSegmentationExecution a hi:TaskExecution ;
    rdfs:label "Archive video segmentation execution"@en ;
    hi:hasInputData hi:ArchivalFootageDataset ;
    hi:hasInteractionEpisode hi:ArchivalGovernanceInteraction ;
    hi:hasOutputData hi:TaggedArchivalSegments ;
    hi:performedBy hi:ArchivalFootageAISystem ;
    hi:realizesTask hi:ArchiveVideoSegmentationTask ;
    hi:towardsGoal hi:PreserveAndCurateArchivalKnowledgeGoal ;
    hi:usesModel hi:ArchivalSegmentationModel .

hi:BiometricsAndForensicsDomain a hi:Domain ;
    rdfs:label "Biometrics and forensics"@en .

hi:BlockSuspiciousTrafficExecution a hi:TaskExecution ;
    rdfs:label "Blocking suspicious traffic execution"@en ;

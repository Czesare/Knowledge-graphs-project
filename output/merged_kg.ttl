inst:Scenario_03_Exec_NaoStimuliResponse a hi:TaskExecution ;
    rdfs:label "NAO Stimuli Response" ;
    hi:hasMethodConcept hint:DataCollectionMethod .

inst:Scenario_03_Experiment_LearningOutcomeExperiment a hi:Experiment ;
    rdfs:label "Learning Outcome Experiment" ;
    hi:hasAlternativeHypothesis "The intervention improves learning outcomes."^^xsd:string ;
    hi:hasExperimentConcept hint:OnlineTutoringExperiment ;
    hi:hasMetricTested hint:LearningGainMetric ;
    hi:hasNullHypothesis "The intervention does not improve learning outcomes."^^xsd:string .

inst:Scenario_03_Goal_ImproveLearningOutcomes a hi:Goal ;
    rdfs:label "Improve Learning Outcomes" ;
    hi:hasGoalConcept hint:EffectiveLearningGoal ;
    hi:requiresTask inst:Scenario_03_Task_BehaviorTrainingTask,
        inst:Scenario_03_Task_ChildAssessmentTask,
        inst:Scenario_03_Task_EducationalPlanningTask,
        inst:Scenario_03_Task_GuidedInteractionTask,
        inst:Scenario_03_Task_RobotInteractionTask .

inst:Scenario_03_Leah_Cap_PedagogicalSkills a hi:Capability ;
    rdfs:label "Pedagogical Skills" ;
    hi:hasCapabilityConcept hint:ReasoningCapability .

inst:Scenario_03_NaoRobot_Cap_ReactiveResponse a hi:Capability ;
    rdfs:label "Reactive Response" ;
    hi:hasCapabilityConcept hint:SensingCapability .

inst:Scenario_03_NaoRobot_Cap_WizardOfOzInteraction a hi:Capability ;
    rdfs:label "Wizard of Oz Interaction" ;
    hi:hasCapabilityConcept hint:OperatorCoordinationCapability .


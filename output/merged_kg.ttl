    hi:hasCapabilityConcept hint:ClinicalJudgmentCapability .

inst:Scenario_03_Context a hi:Context ;
    rdfs:label "School Intervention Context" ;
    hi:hasConstraintConcept hint:AutonomyConstraint,
        hint:TransparencyConstraint ;
    hi:hasContextConcept hint:OnlineLearningContext ;
    hi:hasInfluenceOn inst:Scenario_03_Team ;
    hi:hasPhenomenonConcept hint:SkillsComplementarityPhenomenon,
        hint:TrustShiftPhenomenon .

inst:Scenario_03_Exec_AnnasChildAssessment a hi:TaskExecution ;

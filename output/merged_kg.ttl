inst:Paper_01_Author1 a hi:Author ;
    foaf:name "Shubhalaxmi Mukherjee" ;
    hi:hasAffiliation inst:Affiliation_DelftUniversityOfTechnology ;
    hi:hasAuthorName "Shubhalaxmi Mukherjee"^^xsd:string .

inst:Paper_01_Author2 a hi:Author ;
    foaf:name "Catholijn M. Jonker" ;
    hi:hasAffiliation inst:Affiliation_DelftUniversityOfTechnology ;
    hi:hasAuthorName "Catholijn M. Jonker"^^xsd:string .

inst:Paper_01_Author3 a hi:Author ;
    foaf:name "Pradeep K. Murukannaiah" ;
    hi:hasAffiliation inst:Affiliation_DelftUniversityOfTechnology ;
    hi:hasAuthorName "Pradeep K. Murukannaiah"^^xsd:string .

inst:Paper_01_Context a hi:Context ;
    rdfs:label "Fact-checking context" ;
    hi:hasConstraintConcept hint:EthicalConstraint,
        hint:TransparencyConstraint ;
    hi:hasContextConcept hint:JuryDeliberationContext ;
    hi:hasInfluenceOn inst:Paper_01_Team ;
    hi:hasPhenomenonConcept hint:KnowledgeMismatchPhenomenon,
        hint:TrustShiftPhenomenon .

inst:Paper_01_Exec_GenerateQuestions a hi:TaskExecution ;
    rdfs:label "Generate Questions" ;
    hi:evaluatedBy inst:Paper_01_Evaluation ;
    hi:hasMethodConcept hint:CooperativeLearningMethod ;
    hi:realizesTask inst:Paper_01_Task_QuestionGeneration .

inst:Paper_01_Exec_PredictVeracity a hi:TaskExecution ;
    rdfs:label "Predict Veracity" ;
    hi:evaluatedBy inst:Paper_01_Evaluation ;
    hi:hasMethodConcept hint:SemanticEmbeddingMethod ;
    hi:realizesTask inst:Paper_01_Task_VeracityPrediction .

inst:Paper_01_Exec_RetrieveEvidence a hi:TaskExecution ;
    rdfs:label "Retrieve Evidence" ;
    hi:evaluatedBy inst:Paper_01_Evaluation ;
    hi:hasMethodConcept hint:DataCollectionMethod ;
    hi:realizesTask inst:Paper_01_Task_EvidenceRetrieval .

inst:Paper_01_Experiment_QuestionGenerationImpact a hi:Experiment ;
    rdfs:label "Question Generation Impact" ;
    hi:hasAlternativeHypothesis "LLM-generated questions improve veracity prediction accuracy."^^xsd:string ;
    hi:hasExperimentConcept hint:DeliberationSupportExperiment ;
    hi:hasMetricTested hint:ExplanationClarityMetric ;
    hi:hasNullHypothesis "LLM-generated questions do not improve veracity prediction accuracy."^^xsd:string .

inst:Paper_01_Goal_VerifyClaims a hi:Goal ;
    rdfs:label "Verify Claims" ;
    hi:hasGoalConcept hint:FairAccurateVerdictGoal ;
    hi:requiresTask inst:Paper_01_Task_EvidenceRetrieval,
        inst:Paper_01_Task_QuestionGeneration,
        inst:Paper_01_Task_VeracityPrediction .

inst:Paper_01_LargeLanguageModel_Cap_TextGeneration a hi:Capability ;
    rdfs:label "Text Generation" ;
    hi:hasCapabilityConcept hint:ExplainingCapability .

inst:Paper_01_ProfessionalFact-checker_Cap_ContextualUnderstanding a hi:Capability ;
    rdfs:label "Contextual Understanding" ;
    hi:hasCapabilityConcept hint:SituationalAwarenessCapability .

inst:Paper_01_ProfessionalFact-checker_Cap_DomainJudgment a hi:Capability ;
    rdfs:label "Domain Judgment" ;
    hi:hasCapabilityConcept hint:ClinicalJudgmentCapability .

inst:Paper_01_UseCase a hi:ResearchUseCase ;
    rdfs:label "Complex Claim Verification" ;
    hi:hasDomainConcept hint:LawAndPolicyDomain ;

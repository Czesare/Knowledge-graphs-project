    hi:hasMethodConcept hint:MetaAnalysisScoringMethod ;
    hi:realizesTask inst:Scenario_03_Task_ChildAssessmentTask .

inst:Scenario_03_Exec_LeahsEducationalPlanning a hi:TaskExecution ;

@prefix bibo: <http://purl.org/ontology/bibo/> .
@prefix dbr: <http://dbpedia.org/resource/> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix hi: <https://w3id.org/hi-ontology#> .
@prefix hint: <https://w3id.org/hi-thesaurus/> .
@prefix inst: <https://w3id.org/hi-ontology/instances/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix wd: <http://www.wikidata.org/entity/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

schema1:PropertyValue a owl:Class ;
    rdfs:label "Property Value"@en ;
    rdfs:comment "A Schema.org class representing a specific property-value pair, often used for metadata or structured descriptions."@en .

hi: a owl:Ontology ;
    dc:description "Conceptual model of Hybrid Intelligence: agents, teams, goals, tasks, capabilities, methods, evaluations, context, and ethical phenomena."@en ;
    dc:license <https://creativecommons.org/licenses/by/4.0/> ;
    dc:title "The Hybrid Intelligence (HI) Ontology"@en ;
    dcterms:created "2025-10-01"^^xsd:date ;
    vann:preferredNamespacePrefix "hi" ;
    vann:preferredNamespaceUri "https://w3id.org/hi-ontology#" ;
    owl:versionInfo "2.0.0" .

hi:evaluatedBy a owl:ObjectProperty ;
    rdfs:label "evaluated by" ;
    rdfs:comment "Execution is evaluated by a defined evaluation."@en ;
    rdfs:domain hi:TaskExecution ;
    rdfs:range hi:Evaluation .

hi:executesTask a owl:ObjectProperty ;
    rdfs:label "executes task" ;
    rdfs:comment "Agent executes a task (derivable from Agent→Execution→Task)."@en ;
    rdfs:domain hi:Agent ;
    rdfs:range hi:Task ;
    rdfs:subPropertyOf hi:isAssignedToTask ;
    owl:propertyChainAxiom ( hi:performsExecution hi:realizesTask ) .

hi:hasAbstract a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "has abstract"@en ;
    rdfs:comment "The abstract text of a research paper."@en ;
    rdfs:domain hi:Paper ;
    rdfs:range xsd:string .

hi:hasAffiliation a owl:ObjectProperty ;
    rdfs:label "has affiliation"@en ;
    rdfs:comment "Links an author to their institutional affiliation."@en ;
    rdfs:domain hi:Author ;
    rdfs:range hi:Affiliation .

hi:hasAgentConcept a owl:ObjectProperty ;
    rdfs:label "has agent concept" ;
    rdfs:comment "Links an agent to a concept in the HINT thesaurus."@en ;
    rdfs:domain hi:Agent ;
    rdfs:range skos:Concept .

hi:hasAlternativeHypothesis a owl:DatatypeProperty ;
    rdfs:label "has alternative hypothesis"@en ;
    rdfs:comment "Stores the textual formulation of the alternative hypothesis of an experiment."@en ;
    rdfs:domain hi:Experiment ;
    rdfs:range xsd:string .

hi:hasAuthorName a owl:DatatypeProperty ;
    rdfs:label "has author name"@en ;
    rdfs:comment "The full name of an author."@en ;
    rdfs:domain hi:Author ;
    rdfs:range xsd:string .

hi:hasCapabilityConcept a owl:ObjectProperty ;
    rdfs:label "has capability concept" ;
    rdfs:comment "Links a capability to a concept in the HINT thesaurus."@en ;
    rdfs:domain hi:Capability ;
    rdfs:range skos:Concept .

hi:hasConferenceName a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "has conference name"@en ;
    rdfs:comment "The name of an academic conference."@en ;
    rdfs:domain hi:Conference ;
    rdfs:range xsd:string .

hi:hasConferenceYear a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "has conference year"@en ;
    rdfs:comment "The year a conference took place."@en ;
    rdfs:domain hi:Conference ;
    rdfs:range xsd:gYear .

hi:hasConstraintConcept a owl:ObjectProperty ;
    rdfs:label "has constraint concept" ;
    rdfs:comment "Specifies the constraint using a concept in the HINT thesaurus."@en ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( hi:Context hi:HITeam hi:Agent ) ] ;
    rdfs:range skos:Concept .

hi:hasContextConcept a owl:ObjectProperty ;
    rdfs:label "has context concept" ;
    rdfs:comment "Links a context to a concept in the HINT thesaurus."@en ;
    rdfs:domain hi:Context ;
    rdfs:range skos:Concept .

hi:hasDOI a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "has DOI"@en ;
    rdfs:comment "The Digital Object Identifier of a paper. Functional: a paper has at most one DOI."@en ;
    rdfs:domain hi:Paper ;
    rdfs:range xsd:string .

hi:hasDomainConcept a owl:ObjectProperty ;
    rdfs:label "has domain concept" ;
    rdfs:comment "Links a domain to a concept in the HINT thesaurus."@en ;
    rdfs:domain hi:UseCase ;
    rdfs:range skos:Concept .

hi:hasEvaluationConcept a owl:ObjectProperty ;
    rdfs:label "has evaluation concept" ;
    rdfs:comment "Links an evaluation to a concept in the HINT thesaurus."@en ;
    rdfs:domain hi:Evaluation ;
    rdfs:range skos:Concept .

hi:hasExecutionConcept a owl:ObjectProperty ;
    rdfs:label "has execution concept" ;
    rdfs:comment "Links an experiment to a concept in the HINT thesaurus."@en ;
    rdfs:domain hi:TaskExecution ;
    rdfs:range skos:Concept .

hi:hasExperiment a owl:ObjectProperty ;
    rdfs:label "has experiment" ;
    rdfs:comment "An evaluation has an experiment."@en ;
    rdfs:domain hi:Evaluation ;
    rdfs:range hi:Experiment .

hi:hasExperimentConcept a owl:ObjectProperty ;
    rdfs:label "has experiment concept" ;
    rdfs:comment "Links an experiment to a concept in the HINT thesaurus."@en ;
    rdfs:domain hi:Experiment ;
    rdfs:range skos:Concept .

hi:hasGoalConcept a owl:ObjectProperty ;
    rdfs:label "has goal concept" ;
    rdfs:comment "Links a goal to a concept in the HINT thesaurus."@en ;
    rdfs:domain hi:Goal ;
    rdfs:range skos:Concept .

hi:hasInteractionEpisode a owl:ObjectProperty ;
    rdfs:label "has interaction episode" ;
    rdfs:comment "Identifies moments of interaction (e.g., dialogue, negotiation, or guidance) that unfold within the execution of a task."@en ;
    rdfs:domain hi:TaskExecution ;
    rdfs:range hi:Interaction .

hi:hasInteractionIntentConcept a owl:ObjectProperty ;
    rdfs:label "has interaction intent concept" ;
    rdfs:comment "Intent underlying the interaction (e.g., explain, request, negotiate)."@en ;
    rdfs:domain hi:Interaction ;
    rdfs:range skos:Concept .

hi:hasInteractionModalityConcept a owl:ObjectProperty ;
    rdfs:label "has interaction modality concept" ;
    rdfs:comment "Modality/channel used during the interaction."@en ;
    rdfs:domain hi:Interaction ;
    rdfs:range skos:Concept .

hi:hasKeyword a owl:ObjectProperty ;
    rdfs:label "has keyword"@en ;
    rdfs:comment "Links a paper to a keyword concept, typically from the HINT thesaurus."@en ;
    rdfs:domain hi:Paper ;
    rdfs:range skos:Concept .

hi:hasMethodConcept a owl:ObjectProperty ;
    rdfs:label "has method concept" ;
    rdfs:comment "Links a task execution to a method in the HINT thesaurus."@en ;
    rdfs:domain hi:TaskExecution ;
    rdfs:range skos:Concept .

hi:hasMetricConcept a owl:ObjectProperty ;
    rdfs:label "has metric concept" ;
    rdfs:comment "An evaluation uses certain metrics, defined in the HINT thesaurus"@en ;
    rdfs:domain hi:Evaluation ;
    rdfs:range skos:Concept .

hi:hasMetricTested a owl:ObjectProperty ;
    rdfs:label "has metric tested" ;
    rdfs:comment "An experiment tests certain metrics, defined in the HINT thesaurus"@en ;
    rdfs:domain hi:Experiment ;
    rdfs:range skos:Concept .

hi:hasNullHypothesis a owl:DatatypeProperty ;
    rdfs:label "has null hypothesis"@en ;
    rdfs:comment "Stores the textual formulation of the null hypothesis of an experiment."@en ;
    rdfs:domain hi:Experiment ;
    rdfs:range xsd:string .

hi:hasPhenomenonConcept a owl:ObjectProperty ;
    rdfs:label "has phenomenon concept" ;
    rdfs:comment "Context exhibits a phenomenon (e.g., bias/feedback emerges in that context)."@en ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( hi:Context hi:HITeam hi:Agent ) ] ;
    rdfs:range skos:Concept .

hi:hasPublicationYear a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "has publication year"@en ;
    rdfs:comment "The year a paper was published."@en ;
    rdfs:domain hi:Paper ;
    rdfs:range xsd:gYear .

hi:hasRoleConcept a owl:ObjectProperty ;
    rdfs:label "has role concept" ;
    rdfs:comment "Links a role to a concept in the HINT thesaurus."@en ;
    rdfs:domain hi:Agent ;
    rdfs:range skos:Concept .

hi:hasScenarioDescription a owl:DatatypeProperty ;
    rdfs:label "has scenario description"@en ;
    rdfs:comment "A textual description of a competition scenario."@en ;
    rdfs:domain hi:CompetitionUseCase ;
    rdfs:range xsd:string .

hi:hasScenarioOutcome a owl:DatatypeProperty ;
    rdfs:label "has scenario outcome"@en ;
    rdfs:comment "Whether this is a best-case or worst-case scenario outcome."@en ;
    rdfs:domain hi:CompetitionUseCase ;
    rdfs:range xsd:string .

hi:hasSubTask a owl:ObjectProperty,
        owl:TransitiveProperty ;
    rdfs:label "has sub-task"@en ;
    rdfs:comment "Decomposes a task into sub-tasks. Transitive: if task A has sub-task B, and B has sub-task C, then A has sub-task C."@en ;
    rdfs:domain hi:Task ;
    rdfs:range hi:Task .

hi:hasTaskConcept a owl:ObjectProperty ;
    rdfs:label "has task concept" ;
    rdfs:comment "Links a task to a concept in the HINT thesaurus."@en ;
    rdfs:domain hi:Task ;
    rdfs:range skos:Concept .

hi:hasTitle a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "has title"@en ;
    rdfs:comment "The title of a research paper. Functional: a paper has exactly one title."@en ;
    rdfs:domain hi:Paper ;
    rdfs:range xsd:string .

hi:hasUseCaseConcept a owl:ObjectProperty ;
    rdfs:label "has use case concept" ;
    rdfs:comment "Links a use case to a concept in the HINT thesaurus."@en ;
    rdfs:domain hi:UseCase ;
    rdfs:range skos:Concept .

hi:introducesTeam a owl:ObjectProperty ;
    rdfs:label "introduces team"@en ;
    rdfs:comment "Inverse of hasHITeam. Links a team back to the use case that introduces it."@en ;
    rdfs:domain hi:HITeam ;
    rdfs:range hi:UseCase ;
    owl:inverseOf hi:hasHITeam .

hi:isInfluencedBy a owl:ObjectProperty ;
    rdfs:label "is influenced by" ;
    rdfs:comment "Related a HI Team to the contextual condition that affects its actions, collaboration dynamics, or task performance."@en ;
    rdfs:domain hi:HITeam ;
    rdfs:range hi:Context ;
    owl:inverseOf hi:hasInfluenceOn .

hi:isMemberOf a owl:ObjectProperty ;
    rdfs:label "is member of"@en ;
    rdfs:comment "Inverse of hasMember. Links an agent to the HI team they belong to."@en ;
    rdfs:domain hi:Agent ;
    rdfs:range hi:HITeam ;
    owl:inverseOf hi:hasMember .

hi:operatesInContext a owl:ObjectProperty ;
    rdfs:label "operates in context" ;
    rdfs:comment "Specifies the context in which an HI team operates."@en ;
    rdfs:domain hi:Agent ;
    rdfs:range hi:Context .

hi:performedBy a owl:ObjectProperty ;
    rdfs:label "performed by" ;
    rdfs:comment "Execution performed by an agent."@en ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( hi:TaskExecution ) ] ;
    rdfs:range hi:Agent ;
    owl:inverseOf hi:performsExecution .

hi:publishedAt a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "published at"@en ;
    rdfs:comment "Links a paper to the conference where it was published. A paper is published at exactly one conference."@en ;
    rdfs:domain hi:Paper ;
    rdfs:range hi:Conference .

hi:realizedBy a owl:ObjectProperty ;
    rdfs:label "realized by" ;
    rdfs:comment "A task is realized through a task execution."@en ;
    rdfs:domain hi:Task ;
    rdfs:range hi:TaskExecution ;
    owl:inverseOf hi:realizesTask .

hi:towardsGoal a owl:ObjectProperty ;
    rdfs:label "towards goal" ;
    rdfs:comment "Task execution towards a goal."@en ;
    rdfs:domain hi:TaskExecution ;
    rdfs:range hi:Goal .


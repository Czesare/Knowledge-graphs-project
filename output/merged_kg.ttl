    hi:requiresCapability inst:Paper_04_HumanAnnotator_Cap_JudgmentCapability,
        inst:Paper_04_HumanAnnotator_Cap_PerceptionCapability .

inst:Paper_04_Task_ProvideMatchingSuggestion a hi:Task ;
    rdfs:label "Provide Matching Suggestion" ;

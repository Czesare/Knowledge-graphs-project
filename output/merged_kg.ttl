        inst:Paper_01_ProfessionalFact-checker_Cap_EthicalOversight,
        inst:Paper_01_ProfessionalFact-checker_Cap_FeedbackProvision ;
    hi:hasRoleConcept hint:JurorRole ;
    hi:performsExecution inst:Paper_01_Exec_DecomposeClaim .

inst:Paper_01_Task_EvidenceAssessment a hi:Task ;
    rdfs:label "Evidence Assessment" ;
    hi:hasTaskConcept hint:AssessCommunicationAccuracy ;
    hi:requiresCapability inst:Paper_01_ProfessionalFact-checker_Cap_DomainJudgment .

inst:Paper_01_Team a hi:HITeam ;

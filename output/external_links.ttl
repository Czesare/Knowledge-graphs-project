@prefix foaf:    <http://xmlns.com/foaf/0.1/> .
@prefix schema:  <http://schema.org/> .
@prefix dul:     <http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#> .


#################################################################
#
# EXTERNAL LINKS for the HI Knowledge Graph
#
# This file links instances, thesaurus concepts, and ontology
# schema elements to external knowledge bases: Wikidata, DBpedia,
# and standard vocabularies (DUL, Dublin Core, BIBO, Schema.org).
#
#################################################################


#################################################################
# SECTION 1: Schema-Level Links
# Mapping HI ontology classes and properties to external
# vocabularies (DBpedia Ontology, DUL, Dublin Core, BIBO).
#################################################################

### Class alignments

hi:Agent owl:equivalentClass dul:Agent ;
    skos:closeMatch dbo:Agent .

hi:HumanAgent skos:closeMatch dbo:Person ;
    skos:closeMatch wd:Q5 .

hi:ArtificialAgent skos:closeMatch dbo:Software ;
    skos:closeMatch wd:Q11660 .

hi:Task owl:equivalentClass dul:Task .

hi:Goal owl:equivalentClass dul:Goal .

hi:Capability skos:closeMatch dul:Quality ;
    skos:relatedMatch wd:Q1137655 .

hi:Context skos:closeMatch dul:Situation .

hi:Evaluation skos:closeMatch wd:Q1379672 .

hi:Experiment skos:closeMatch wd:Q101965 ;
    rdfs:seeAlso dbr:Experiment .

hi:Interaction skos:closeMatch wd:Q80919 ;
    rdfs:seeAlso dbr:Human%E2%80%93computer_interaction .

hi:UseCase skos:closeMatch wd:Q1472399 ;
    rdfs:seeAlso dbr:Use_case .

hi:HITeam skos:relatedMatch wd:Q327245 ;
    rdfs:seeAlso dbr:Human%E2%80%93computer_interaction .

hi:Paper rdfs:subClassOf bibo:AcademicArticle ;
    skos:closeMatch wd:Q13442814 .

hi:Author skos:closeMatch wd:Q482980 ;
    rdfs:seeAlso dbr:Author .

hi:Conference skos:closeMatch wd:Q2020153 ;
    rdfs:seeAlso dbr:Academic_conference .

hi:Affiliation skos:closeMatch wd:Q4830453 .

hi:TaskExecution skos:relatedMatch dul:Action .

hi:ResearchUseCase skos:relatedMatch wd:Q1438073 .

hi:CompetitionUseCase skos:relatedMatch wd:Q476300 .

### Property alignments

hi:hasTitle rdfs:subPropertyOf dcterms:title .

hi:hasAuthor rdfs:subPropertyOf dcterms:creator .

hi:hasKeyword rdfs:subPropertyOf dcterms:subject .

hi:hasPublicationYear rdfs:subPropertyOf dcterms:date .

hi:hasDOI rdfs:subPropertyOf bibo:doi .

hi:hasAbstract rdfs:subPropertyOf dcterms:abstract .

hi:publishedAt skos:closeMatch bibo:presentedAt .

hi:hasAffiliation skos:closeMatch schema:affiliation .

hi:hasAuthorName rdfs:subPropertyOf foaf:name .


